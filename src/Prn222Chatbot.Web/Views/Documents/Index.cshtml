@model Prn222Chatbot.Web.ViewModels.DocumentIndexViewModel
@{
    ViewData["Title"] = "Documents";
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card app-card">
            <div class="card-body">
                <h5 class="card-title">Upload PRN222 Documents</h5>
                <p class="text-muted small">Supports PDF, DOCX, TXT, and MD. Limit: 20MB per file.</p>
                @if (!string.IsNullOrWhiteSpace(Model.Message))
                {
                    <div class="alert alert-success small">@Model.Message</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Error))
                {
                    <div class="alert alert-danger small">@Model.Error</div>
                }
                <form asp-action="Upload" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label">Chapter</label>
                        <select class="form-select" name="chapterId" required>
                            @foreach (var chapter in Model.Chapters)
                            {
                                <option value="@chapter.Id">@chapter.Order. @chapter.Title</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">File</label>
                        <input class="form-control" type="file" name="file" accept=".pdf,.docx,.txt,.md" required />
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Upload & Queue Indexing</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card app-card">
            <div class="card-body">
                <h5 class="card-title">Indexed Documents</h5>
                <form method="get" action="/documents" class="row g-2 align-items-end mb-3">
                    <div class="col-md-5">
                        <label class="form-label small text-muted" for="searchTerm">File name</label>
                        <input id="searchTerm" class="form-control form-control-sm" type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Search file name..." />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label small text-muted" for="chapterId">Chapter</label>
                        <select id="chapterId" class="form-select form-select-sm" name="chapterId">
                            <option value="">All chapters</option>
                            @foreach (var chapter in Model.Chapters)
                            {
                                if (Model.SelectedChapterId == chapter.Id)
                                {
                                    <option value="@chapter.Id" selected>@chapter.Order. @chapter.Title</option>
                                }
                                else
                                {
                                    <option value="@chapter.Id">@chapter.Order. @chapter.Title</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2 d-flex gap-2">
                        <button class="btn btn-sm btn-primary flex-fill" type="submit">Search</button>
                        <a class="btn btn-sm btn-outline-secondary" href="/documents">Clear</a>
                    </div>
                </form>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                        <tr>
                            <th>File</th>
                            <th>Chapter</th>
                            <th>Status</th>
                            <th>Chunks</th>
                            <th>Uploaded</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        @if (Model.Documents.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-muted small">No documents match the current filters.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var doc in Model.Documents)
                            {
                                <tr>
                                    <td>@doc.OriginalFileName<br><span class="text-muted small">@doc.FileType / @(doc.FileSizeBytes / 1024) KB</span></td>
                                    <td>@doc.Chapter?.Title</td>
                                    <td><span class="badge bg-secondary">@doc.IndexStatus</span></td>
                                    <td>@doc.Chunks.Count</td>
                                    <td class="small">@doc.UploadedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <form method="post" action="/documents/@doc.Id/delete" class="document-delete-form d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                            @if (Model.SelectedChapterId.HasValue)
                                            {
                                                <input type="hidden" name="chapterId" value="@Model.SelectedChapterId.Value" />
                                            }
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                                @if (!string.IsNullOrWhiteSpace(doc.IndexError))
                                {
                                    <tr><td colspan="6" class="text-danger small">@doc.IndexError</td></tr>
                                }
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".document-delete-form").forEach((form) => {
            form.addEventListener("submit", (event) => {
                if (!confirm("Delete this document and all related chunks?")) {
                    event.preventDefault();
                }
            });
        });
    </script>
}
