@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card app-card">
            <div class="card-body">
                <h4 class="card-title">Change Password</h4>

                @if (!string.IsNullOrWhiteSpace(Model.Error))
                {
                    <div class="alert alert-danger small">@Model.Error</div>
                }

                <form method="post" asp-controller="Account" asp-action="ChangePassword">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" asp-for="CurrentPassword"></label>
                        <input class="form-control" id="CurrentPassword" name="CurrentPassword" type="password" value="" autocomplete="current-password" />
                        <span class="text-danger small" asp-validation-for="CurrentPassword"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="NewPassword"></label>
                        <input class="form-control" id="NewPassword" name="NewPassword" type="password" value="" autocomplete="new-password" />
                        <span class="text-danger small" asp-validation-for="NewPassword"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="ConfirmPassword"></label>
                        <input class="form-control" id="ConfirmPassword" name="ConfirmPassword" type="password" value="" autocomplete="new-password" />
                        <span class="text-danger small" asp-validation-for="ConfirmPassword"></span>
                    </div>
                    <button class="btn btn-primary" type="submit">Save</button>
                    <a asp-controller="Chat" asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
