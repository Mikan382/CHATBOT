@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-page">
    <div class="auth-panel">
        <div>
            <div class="auth-kicker">PRN222 Course Support</div>
            <h1>Course Materials Assistant</h1>
            <p>Create a Student account to browse course materials and ask questions answered from uploaded documents.</p>
        </div>
        <div class="auth-meta">
            <span>Documents</span>
            <span>Chapters</span>
            <span>Questions</span>
            <span>References</span>
        </div>
    </div>

    <div class="auth-card card app-card">
        <div class="card-body">
            <h4 class="card-title">Create account</h4>
            <p class="text-muted small">Sign-up creates a Student account. Teacher and Admin accounts are created by an Administrator.</p>

            @if (!string.IsNullOrWhiteSpace(Model.Error))
            {
                <div class="alert alert-danger small">@Model.Error</div>
            }

            <form method="post" asp-controller="Account" asp-action="Register">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />
                <div class="mb-3">
                    <label class="form-label" asp-for="FullName"></label>
                    <input class="form-control" asp-for="FullName" autocomplete="name" />
                    <span class="text-danger small" asp-validation-for="FullName"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label" asp-for="Email"></label>
                    <input class="form-control" asp-for="Email" autocomplete="username" />
                    <span class="text-danger small" asp-validation-for="Email"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label" asp-for="Password"></label>
                    <input class="form-control" id="Password" name="Password" type="password" value="" autocomplete="new-password" />
                    <div class="form-text">At least 8 characters, with an uppercase letter, a lowercase letter, and a digit.</div>
                    <span class="text-danger small" asp-validation-for="Password"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label" asp-for="ConfirmPassword"></label>
                    <input class="form-control" id="ConfirmPassword" name="ConfirmPassword" type="password" value="" autocomplete="new-password" />
                    <span class="text-danger small" asp-validation-for="ConfirmPassword"></span>
                </div>
                <button class="btn btn-primary w-100" type="submit">Create account</button>
            </form>

            <p class="text-muted small mt-3 mb-0">
                Already have an account?
                <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl">Sign in</a>
            </p>
        </div>
    </div>
</div>
