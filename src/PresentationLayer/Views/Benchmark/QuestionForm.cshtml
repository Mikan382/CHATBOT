@model BenchmarkQuestionFormViewModel
@{
    var editing = Model.Id.HasValue;
    var action = editing ? "EditQuestion" : "CreateQuestion";
    ViewData["Title"] = editing ? "Edit Ground Truth" : "Add Ground Truth";
}

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">
        <div class="page-toolbar">
            <div>
                <h2 class="mb-1">@(editing ? "Edit Ground Truth" : "Add Ground Truth")</h2>
                <div class="text-muted">Evaluation question and its expected answer source.</div>
            </div>
            <a class="btn btn-outline-secondary" asp-action="Questions" asp-route-courseId="@Model.CourseId">Back</a>
        </div>

        <div class="card app-card">
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(Model.Error))
                {
                    <div class="alert alert-danger small">@Model.Error</div>
                }
                <form method="post" asp-controller="Benchmark" asp-action="@action" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-8">
                            <label class="form-label" asp-for="CourseId">Course</label>
                            <select class="form-select" asp-for="CourseId" data-benchmark-course-select>
                                <option value="">Select course</option>
                                @foreach (var course in Model.Courses)
                                {
                                    <option value="@course.Id">@course.Code - @course.Name</option>
                                }
                            </select>
                            <span class="text-danger small" asp-validation-for="CourseId"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" asp-for="DisplayOrder">Display order</label>
                            <input class="form-control" asp-for="DisplayOrder" type="number" min="1" max="10000" />
                            <span class="text-danger small" asp-validation-for="DisplayOrder"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="ExpectedDocumentId">Expected source document</label>
                        <select class="form-select" asp-for="ExpectedDocumentId" data-benchmark-document-select>
                            <option value="">Select document</option>
                            @foreach (var document in Model.Documents)
                            {
                                <option value="@document.Id" data-course-id="@document.CourseId">
                                    @document.CourseCode / @document.ChapterTitle / @document.FileName
                                </option>
                            }
                        </select>
                        <span class="text-danger small" asp-validation-for="ExpectedDocumentId"></span>
                        <div class="text-muted small mt-1 d-none" data-benchmark-no-documents>No document is available for this course.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Question">Question</label>
                        <textarea class="form-control" asp-for="Question" rows="3" maxlength="2000"></textarea>
                        <span class="text-danger small" asp-validation-for="Question"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="ExpectedAnswer">Expected answer</label>
                        <textarea class="form-control" asp-for="ExpectedAnswer" rows="7" maxlength="8000"></textarea>
                        <span class="text-danger small" asp-validation-for="ExpectedAnswer"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center gap-3">
                        <label class="form-check mb-0">
                            <input class="form-check-input" asp-for="IsActive" />
                            <span class="form-check-label">Active</span>
                        </label>
                        <button class="btn btn-primary" type="submit">@(editing ? "Save" : "Create")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/benchmark.js" asp-append-version="true"></script>
}
