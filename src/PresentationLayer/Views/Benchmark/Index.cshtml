@model BenchmarkIndexViewModel
@{
    ViewData["Title"] = "Benchmark Dashboard";
    var dashboard = Model.Dashboard;
    var latest = dashboard.Results.FirstOrDefault();
    var completedResults = dashboard.Results.Where(r => r.Status == "Completed").ToList();
    var byModel = dashboard.ByModel;
    var byStrategy = dashboard.ByStrategy;
    var ragVsFt = dashboard.RagVsFt;
}

<div class="card app-card mb-4">
    <div class="card-body">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start gap-3">
            <div>
                <h4 class="mb-1">Benchmark Dashboard</h4>
                <p class="text-muted mb-0">Compare RAG pipeline configurations: chunking strategies × embedding models × RAG vs Fine-tuned.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button id="runBenchmark" class="btn btn-primary">
                    <i class="bi bi-play-fill"></i> Run Benchmark
                </button>
                <button id="runFullBenchmark" class="btn btn-outline-primary">
                    <i class="bi bi-grid-3x3-gap-fill"></i> Full Comparison
                </button>
                <a href="/api/evaluations/export" target="_blank" class="btn btn-outline-secondary">
                    <i class="bi bi-download"></i> Export JSON
                </a>
            </div>
        </div>
        <div id="runOptions" class="mt-3 d-none">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small text-muted">Questions</label>
                    <input id="questionLimit" type="number" class="form-control form-control-sm" value="5" min="1" max="50" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted">Chunking Strategy</label>
                    <select id="chunkingStrategy" class="form-select form-select-sm">
                        <option value="">Default (paragraph)</option>
                        @foreach (var strategy in Model.ChunkingStrategies)
                        {
                            <option value="@strategy">@strategy</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted">Embedding Model</label>
                    <select id="embeddingModel" class="form-select form-select-sm">
                        <option value="">Default</option>
                        @foreach (var embModel in Model.EmbeddingModels)
                        {
                            <option value="@embModel">@embModel</option>
                        }
                    </select>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button id="confirmRun" class="btn btn-sm btn-success w-100">Go</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-2"><div class="metric-card"><span>Gemini</span><strong>@(Model.GeminiConfigured ? "Ready" : "Missing")</strong></div></div>
    <div class="col-md-2"><div class="metric-card"><span>Fine-tuned</span><strong>@(Model.FineTuneConfigured ? "Ready" : "Disabled")</strong></div></div>
    <div class="col-md-2"><div class="metric-card"><span>Questions</span><strong>@dashboard.Questions.Count</strong></div></div>
    <div class="col-md-2"><div class="metric-card"><span>Results</span><strong>@completedResults.Count</strong></div></div>
    <div class="col-md-2"><div class="metric-card"><span>Embed Models</span><strong>@Model.EmbeddingModels.Count</strong></div></div>
    <div class="col-md-2"><div class="metric-card"><span>Latest Faith.</span><strong>@(latest?.Faithfulness.ToString("0.00") ?? "-")</strong></div></div>
</div>

<div id="benchmarkStatus" class="alert alert-info d-none"></div>

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card app-card">
            <div class="card-body">
                <h5>RAGAS Scores by Embedding Model</h5>
                <canvas id="chartByModel" height="250"></canvas>
                @if (byModel.Count == 0)
                {
                    <p class="text-muted small mt-2">No results yet. Run a benchmark to see data.</p>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card app-card">
            <div class="card-body">
                <h5>RAGAS Scores by Chunking Strategy</h5>
                <canvas id="chartByStrategy" height="250"></canvas>
                @if (byStrategy.Count == 0)
                {
                    <p class="text-muted small mt-2">No results yet. Run a benchmark to see data.</p>
                }
            </div>
        </div>
    </div>
</div>

@if (ragVsFt.Count > 0)
{
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card app-card">
                <div class="card-body">
                    <h5>RAG vs Fine-tuned</h5>
                    <canvas id="chartRagVsFt" height="250"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card app-card">
                <div class="card-body">
                    <h5>RAG vs Fine-tuned Summary</h5>
                    <table class="table table-sm">
                        <thead><tr><th>Metric</th><th>RAG (avg)</th><th>Fine-tuned (avg)</th></tr></thead>
                        <tbody>
                            <tr><td>Faithfulness</td><td>@ragVsFt.Average(x => x.Faithfulness).ToString("0.000")</td><td>@ragVsFt.Average(x => x.FtFaithfulness).ToString("0.000")</td></tr>
                            <tr><td>Answer Relevance</td><td>@ragVsFt.Average(x => x.AnswerRelevance).ToString("0.000")</td><td>@ragVsFt.Average(x => x.FtAnswerRelevance).ToString("0.000")</td></tr>
                            <tr><td>Avg Latency (ms)</td><td>@ragVsFt.Average(x => x.RagLatencyMs).ToString("0")</td><td>@ragVsFt.Average(x => x.FineTunedLatencyMs).ToString("0")</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card app-card">
            <div class="card-body">
                <h5>Summary by Embedding Model</h5>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead><tr><th>Model</th><th>Faith</th><th>Rel</th><th>Recall</th><th>Cite</th><th>Count</th></tr></thead>
                        <tbody>
                        @foreach (var row in byModel)
                        {
                            <tr><td>@row.Label</td><td>@row.AvgFaithfulness.ToString("0.000")</td><td>@row.AvgRelevance.ToString("0.000")</td><td>@row.AvgRecall.ToString("0.000")</td><td>@row.AvgCitation.ToString("0.000")</td><td>@row.Count</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card app-card">
            <div class="card-body">
                <h5>Summary by Chunking Strategy</h5>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead><tr><th>Strategy</th><th>Faith</th><th>Rel</th><th>Recall</th><th>Cite</th><th>Count</th></tr></thead>
                        <tbody>
                        @foreach (var row in byStrategy)
                        {
                            <tr><td>@row.Label</td><td>@row.AvgFaithfulness.ToString("0.000")</td><td>@row.AvgRelevance.ToString("0.000")</td><td>@row.AvgRecall.ToString("0.000")</td><td>@row.AvgCitation.ToString("0.000")</td><td>@row.Count</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card app-card mb-4">
    <div class="card-body">
        <h5>Detailed Evaluation Results</h5>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr><th>Question</th><th>Strategy</th><th>Model</th><th>Status</th><th>Faith</th><th>Rel</th><th>Recall</th><th>Cite</th><th>Latency</th></tr>
                </thead>
                <tbody id="resultsBody">
                @foreach (var result in dashboard.Results.Take(100))
                {
                    <tr>
                        <td class="small" style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@result.Question">@result.Question</td>
                        <td><span class="badge bg-secondary">@result.ChunkingStrategy</span></td>
                        <td><span class="badge bg-info text-dark">@(string.IsNullOrWhiteSpace(result.EmbeddingModelName) ? "default" : result.EmbeddingModelName)</span></td>
                        <td>
                            @if (result.Status == "Completed") { <span class="badge bg-success">@result.Status</span> }
                            else { <span class="badge bg-danger" title="@result.ErrorMessage">@result.Status</span> }
                        </td>
                        <td>@result.Faithfulness.ToString("0.00")</td>
                        <td>@result.AnswerRelevance.ToString("0.00")</td>
                        <td>@result.RetrievalRecall.ToString("0.00")</td>
                        <td>@result.CitationAccuracy.ToString("0.00")</td>
                        <td class="small">@(result.RagLatencyMs)ms</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card app-card mb-4">
    <div class="card-body">
        <h5>Question Details (Ground Truth + Answers)</h5>
        <div class="accordion" id="questionAccordion">
        @{ var idx = 0; }
        @foreach (var result in dashboard.Results.Where(r => r.Status == "Completed").Take(20))
        {
            idx++;
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed small" type="button" data-bs-toggle="collapse" data-bs-target="#q@(idx)">
                        Q@(idx): @result.Question
                    </button>
                </h2>
                <div id="q@(idx)" class="accordion-collapse collapse" data-bs-parent="#questionAccordion">
                    <div class="accordion-body small">
                        <div class="mb-2"><strong>Ground Truth:</strong> @result.GroundTruth</div>
                        <div class="mb-2"><strong>RAG Answer:</strong> @result.RagAnswer</div>
                        @if (!string.IsNullOrWhiteSpace(result.FineTunedAnswer))
                        {
                            <div class="mb-2"><strong>Fine-tuned Answer:</strong> @result.FineTunedAnswer</div>
                        }
                        <div class="row g-2 mt-1">
                            <div class="col-auto"><span class="badge bg-primary">Faith: @result.Faithfulness.ToString("0.00")</span></div>
                            <div class="col-auto"><span class="badge bg-primary">Rel: @result.AnswerRelevance.ToString("0.00")</span></div>
                            <div class="col-auto"><span class="badge bg-primary">Recall: @result.RetrievalRecall.ToString("0.00")</span></div>
                            <div class="col-auto"><span class="badge bg-primary">Cite: @result.CitationAccuracy.ToString("0.00")</span></div>
                            <div class="col-auto"><span class="badge bg-secondary">@result.ChunkingStrategy</span></div>
                            <div class="col-auto"><span class="badge bg-info text-dark">@result.EmbeddingModelName</span></div>
                        </div>
                    </div>
                </div>
            </div>
        }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        // Chart data from server (aggregation now done in BL — fix #4)
        const modelLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(byModel.Select(x => x.Label)));
        const modelFaith = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(byModel.Select(x => Math.Round(x.AvgFaithfulness, 3))));
        const modelRel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(byModel.Select(x => Math.Round(x.AvgRelevance, 3))));
        const modelRecall = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(byModel.Select(x => Math.Round(x.AvgRecall, 3))));
        const modelCite = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(byModel.Select(x => Math.Round(x.AvgCitation, 3))));

        const stratLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(byStrategy.Select(x => x.Label)));
        const stratFaith = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(byStrategy.Select(x => Math.Round(x.AvgFaithfulness, 3))));
        const stratRel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(byStrategy.Select(x => Math.Round(x.AvgRelevance, 3))));
        const stratRecall = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(byStrategy.Select(x => Math.Round(x.AvgRecall, 3))));
        const stratCite = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(byStrategy.Select(x => Math.Round(x.AvgCitation, 3))));

        @if (ragVsFt.Count > 0)
        {
            <text>
            const ragFaith = @ragVsFt.Average(x => x.Faithfulness).ToString("0.000");
            const ragRel = @ragVsFt.Average(x => x.AnswerRelevance).ToString("0.000");
            const ftFaith = @ragVsFt.Average(x => x.FtFaithfulness).ToString("0.000");
            const ftRel = @ragVsFt.Average(x => x.FtAnswerRelevance).ToString("0.000");
            </text>
        }
    </script>
    <script src="~/js/benchmark.js" asp-append-version="true"></script>
}
