@model BenchmarkDashboardViewModel
@{
    ViewData["Title"] = "RAG Benchmark";
    var dashboard = Model.Dashboard;
    var selectedCourse = dashboard.Courses.FirstOrDefault(x => x.Id == dashboard.SelectedCourseId);
    var canRun = dashboard.Courses.Count > 0
        && dashboard.AvailableChunkingStrategies.Count > 0
        && dashboard.AvailableEmbeddingModels.Count > 0
        && dashboard.ActiveQuestions > 0
        && dashboard.GeminiConfigured
        && dashboard.EmbeddingConfigured;
}

<div class="benchmark-page">
    <div class="page-toolbar">
        <div>
            <h2 class="mb-1">RAG Benchmark</h2>
            <div class="text-muted">Chunking and embedding experiment results.</div>
        </div>
        <div class="benchmark-toolbar-actions">
            <form method="get" asp-action="Index">
                <label class="visually-hidden" for="dashboardCourseId">Dashboard course</label>
                <select class="form-select" id="dashboardCourseId" name="courseId" onchange="this.form.submit()">
                    @foreach (var course in dashboard.Courses)
                    {
                        <option value="@course.Id" selected="@(course.Id == dashboard.SelectedCourseId)">@course.Code - @course.Name</option>
                    }
                </select>
            </form>
            <a class="btn btn-outline-primary" asp-controller="Benchmark" asp-action="Questions" asp-route-courseId="@dashboard.SelectedCourseId">
                Ground truth questions
            </a>
        </div>
    </div>

    @if (!dashboard.GeminiConfigured || !dashboard.EmbeddingConfigured)
    {
        <div class="alert alert-warning small">
            @if (!dashboard.GeminiConfigured)
            {
                <div>Gemini API key is not configured.</div>
            }
            @if (!dashboard.EmbeddingConfigured)
            {
                <div>Hugging Face embedding models or API key are not configured.</div>
            }
        </div>
    }

    <div class="benchmark-stat-grid">
        <div class="benchmark-stat">
            <span>Ground truth</span>
            <strong>@dashboard.ActiveQuestions / @dashboard.TotalQuestions</strong>
        </div>
        <div class="benchmark-stat">
            <span>Compared combinations</span>
            <strong>@dashboard.LatestComparisons.Count</strong>
        </div>
        <div class="benchmark-stat">
            <span>Chunking strategies</span>
            <strong>@dashboard.AvailableChunkingStrategies.Count</strong>
        </div>
        <div class="benchmark-stat">
            <span>Embedding models</span>
            <strong>@dashboard.AvailableEmbeddingModels.Count</strong>
        </div>
    </div>

    <div class="card app-card mb-4">
        <div class="card-body">
            <h5 class="card-title">Run Experiment</h5>
            <form method="post" asp-controller="Benchmark" asp-action="Run" class="benchmark-run-form" data-benchmark-run-form>
                @Html.AntiForgeryToken()
                <input type="hidden" name="CourseId" value="@dashboard.SelectedCourseId" />
                <div>
                    <label class="form-label" for="benchmarkCourse">Course</label>
                    <input class="form-control" id="benchmarkCourse" value="@(selectedCourse is null ? "No course" : $"{selectedCourse.Code} - {selectedCourse.Name}")" readonly />
                </div>
                <div>
                    <label class="form-label" for="chunkingStrategy">Chunking</label>
                    <select class="form-select" id="chunkingStrategy" name="ChunkingStrategy" required>
                        @foreach (var strategy in dashboard.AvailableChunkingStrategies)
                        {
                            <option value="@strategy">@strategy</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label" for="embeddingModel">Embedding model</label>
                    <select class="form-select" id="embeddingModel" name="EmbeddingModel" required>
                        @foreach (var embeddingModel in dashboard.AvailableEmbeddingModels)
                        {
                            <option value="@embeddingModel">@embeddingModel</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label" for="topK">Top K</label>
                    <input class="form-control" id="topK" name="TopK" type="number" value="3" min="1" max="10" required />
                </div>
                <div class="benchmark-run-action">
                    @if (canRun)
                    {
                        <button class="btn btn-primary" type="submit" data-benchmark-run-button>Run</button>
                    }
                    else
                    {
                        <button class="btn btn-primary" type="button" disabled>Run</button>
                    }
                </div>
            </form>
            <div class="benchmark-running d-none" data-benchmark-running aria-live="polite">
                <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                <span>Running benchmark...</span>
            </div>
        </div>
    </div>

    <div class="card app-card mb-4">
        <div class="card-body">
            <h5 class="card-title">Latest Comparison</h5>
            <div class="table-responsive">
                <table class="table align-middle benchmark-comparison-table">
                    <thead>
                    <tr>
                        <th>Chunking</th>
                        <th>Embedding model</th>
                        <th class="text-end">Hit@K</th>
                        <th class="text-end">MRR</th>
                        <th class="text-end">Token F1</th>
                        <th class="text-end">Avg latency</th>
                        <th class="text-end">K</th>
                        <th class="text-end">Questions</th>
                        <th class="text-end">Chunks</th>
                        <th>Completed</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (dashboard.LatestComparisons.Count == 0)
                    {
                        <tr><td colspan="11" class="text-muted text-center py-4">No benchmark result for this course.</td></tr>
                    }
                    else
                    {
                        @foreach (var run in dashboard.LatestComparisons)
                        {
                            <tr>
                                <td><span class="benchmark-code">@run.ChunkingStrategy</span></td>
                                <td class="text-break">@run.EmbeddingModelName</td>
                                <td class="text-end fw-semibold">@run.HitRate.ToString("P1")</td>
                                <td class="text-end">@run.MeanReciprocalRank.ToString("F3")</td>
                                <td class="text-end">@run.AverageAnswerTokenF1.ToString("P1")</td>
                                <td class="text-end">@run.AverageLatencyMilliseconds.ToString("F0") ms</td>
                                <td class="text-end">@run.TopK</td>
                                <td class="text-end">@run.QuestionCount</td>
                                <td class="text-end">@run.ChunkCount</td>
                                <td>@run.CompletedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end"><a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@run.Id">Details</a></td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card app-card">
        <div class="card-body">
            <h5 class="card-title">Recent Runs</h5>
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>Completed</th>
                        <th>Course</th>
                        <th>Combination</th>
                        <th>Questions</th>
                        <th>Duration</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (dashboard.RecentRuns.Count == 0)
                    {
                        <tr><td colspan="6" class="text-muted text-center py-3">No completed runs.</td></tr>
                    }
                    else
                    {
                        @foreach (var run in dashboard.RecentRuns)
                        {
                            <tr>
                                <td>@run.CompletedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                <td>@run.CourseCode</td>
                                <td>@run.ChunkingStrategy · @run.EmbeddingModelName</td>
                                <td>@run.QuestionCount</td>
                                <td>@TimeSpan.FromMilliseconds(run.DurationMilliseconds).ToString(@"mm\:ss")</td>
                                <td class="text-end"><a asp-action="Details" asp-route-id="@run.Id">View</a></td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/benchmark.js" asp-append-version="true"></script>
}
