@model CourseFormViewModel
@{
    ViewData["Title"] = "Create Course";
}

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">
        <div class="card app-card">
            <div class="card-body">
                <h4 class="card-title">@ViewData["Title"]</h4>
                @if (!string.IsNullOrWhiteSpace(Model.Error))
                {
                    <div class="alert alert-danger small">@Model.Error</div>
                }
                <form method="post" asp-controller="Courses" asp-action="Create">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" asp-for="Code"></label>
                            <input class="form-control" asp-for="Code" />
                            <span class="text-danger small" asp-validation-for="Code"></span>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label" asp-for="Name"></label>
                            <input class="form-control" asp-for="Name" />
                            <span class="text-danger small" asp-validation-for="Name"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" asp-for="Description"></label>
                            <textarea class="form-control" asp-for="Description" rows="3"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label" asp-for="Tools"></label>
                            <input class="form-control" asp-for="Tools" />
                            <span class="text-danger small" asp-validation-for="Tools"></span>
                        </div>
                        <div class="col-12">
                            <partial name="_TeacherAssignment" model="Model" />
                        </div>
                        <div class="col-12 mt-4">
                            <h6 class="fw-bold border-bottom pb-2 mb-3">AI RAG Configuration (Per Course)</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" asp-for="DefaultChunkingStrategy">Chunking Strategy</label>
                                    <select class="form-select" asp-for="DefaultChunkingStrategy">
                                        <option value="paragraph">Paragraph (Semantic Break)</option>
                                        <option value="fixed">Fixed Size (Character Length)</option>
                                        <option value="sentence">Sentence (Period Break)</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" asp-for="DefaultEmbeddingModel">Embedding Model</label>
                                    <select class="form-select" asp-for="DefaultEmbeddingModel">
                                        <option value="intfloat/multilingual-e5-base">intfloat/multilingual-e5-base</option>
                                        <option value="intfloat/multilingual-e5-small">intfloat/multilingual-e5-small</option>
                                        <option value="intfloat/multilingual-e5-large">intfloat/multilingual-e5-large</option>
                                    </select>
                                </div>
                                <div class="col-md-6" data-fixed-chunk-option>
                                    <label class="form-label" asp-for="DefaultChunkSize">Chunk Size (characters)</label>
                                    <input class="form-control" asp-for="DefaultChunkSize" placeholder="1000" type="number" min="100" max="2000" />
                                    <div class="form-text text-muted small">Only applies to Fixed Size strategy.</div>
                                </div>
                                <div class="col-md-6" data-fixed-chunk-option>
                                    <label class="form-label" asp-for="DefaultChunkOverlap">Chunk Overlap (characters)</label>
                                    <input class="form-control" asp-for="DefaultChunkOverlap" placeholder="150" type="number" min="0" max="500" />
                                    <div class="form-text text-muted small">Only applies to Fixed Size strategy.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <button class="btn btn-primary" type="submit">Save</button>
                        <a class="btn btn-outline-secondary" asp-controller="Courses" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/course-form.js" asp-append-version="true"></script>
}
