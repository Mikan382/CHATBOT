@model PresentationLayer.ViewModels.CourseIndexViewModel
@{
    ViewData["Title"] = "Courses";
}

<div class="card app-card table-card">
    <div class="card-body">
        <div class="page-toolbar">
            <div>
                <h4 class="card-title mb-1">Courses</h4>
                <div class="text-muted small">Manage courses and chapters shown to students.</div>
            </div>
            <a class="btn btn-primary" href="/courses/create">Create Course</a>
        </div>

        <form class="row g-2 mb-3" method="get" action="/courses">
            <div class="col-md-10">
                <input class="form-control" name="searchTerm" value="@Model.SearchTerm" placeholder="Search course code or name..." />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary flex-fill" type="submit">Search</button>
                <a class="btn btn-outline-secondary" href="/courses">Clear</a>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Chapters</th>
                    <th>Tools</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var course in Model.Courses)
                {
                    <tr>
                        <td><strong>@course.Code</strong></td>
                        <td>@course.Name<br><span class="text-muted small">@course.Description</span></td>
                        <td>@course.ChaptersCount</td>
                        <td class="small">@course.Tools</td>
                        <td>
                            <div class="action-cell">
                            <a class="btn btn-sm btn-outline-primary" href="/courses/@course.Id/chapters">Chapters</a>
                            <a class="btn btn-sm btn-outline-secondary" href="/courses/@course.Id/edit">Edit</a>
                            <form method="post" action="/courses/@course.Id/delete" onsubmit="return confirm('Delete this course? It must have no chapters.');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
