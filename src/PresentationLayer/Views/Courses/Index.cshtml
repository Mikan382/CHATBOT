@model CourseIndexViewModel
@{
    ViewData["Title"] = "Courses";
}

<div class="card app-card table-card management-dropdown-card">
    <div class="card-body">
        <div class="page-toolbar">
            <div>
                <h4 class="card-title mb-1">Courses</h4>
                <div class="text-muted small">Manage courses and chapters shown to students.</div>
            </div>
            @if (Model.CanManageCourses)
            {
                <a class="btn btn-primary" asp-controller="Courses" asp-action="Create">Create Course</a>
            }
        </div>

        <form class="row g-2 mb-3" method="get" asp-controller="Courses" asp-action="Index">
            <div class="col-md-10">
                <input class="form-control" name="searchTerm" value="@Model.SearchTerm" placeholder="Search course code or name..." />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary flex-fill" type="submit">Search</button>
                <a class="btn btn-outline-secondary" asp-controller="Courses" asp-action="Index">Clear</a>
            </div>
        </form>

        <div class="table-responsive management-table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Chapters</th>
                    <th>Teachers</th>
                    <th>Tools</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @if (Model.Courses.Count == 0)
                {
                    <tr><td colspan="6" class="text-muted small py-3">No courses match the current filter or assignment.</td></tr>
                }
                else
                {
                    @foreach (var course in Model.Courses)
                    {
                        <tr>
                            <td><strong>@course.Code</strong></td>
                            <td>@course.Name<br><span class="text-muted small">@course.Description</span></td>
                            <td>@course.ChaptersCount</td>
                            <td class="small">@(course.TeacherNames.Count == 0 ? "Unassigned" : string.Join(", ", course.TeacherNames))</td>
                            <td class="small">@course.Tools</td>
                            <td class="management-actions-cell">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                            type="button"
                                            data-bs-toggle="dropdown"
                                            data-bs-boundary="viewport"
                                            aria-expanded="false">
                                        Actions
                                    </button>
                                    <div class="dropdown-menu dropdown-menu-end">
                                        <a class="dropdown-item"
                                           asp-controller="Courses"
                                           asp-action="Chapters"
                                           asp-route-id="@course.Id">
                                            Manage chapters
                                        </a>
                                        @if (Model.CanManageCourses)
                                        {
                                            <a class="dropdown-item"
                                               asp-controller="Courses"
                                               asp-action="Edit"
                                               asp-route-id="@course.Id">
                                                Edit course
                                            </a>
                                            <div class="dropdown-divider"></div>
                                            <form method="post"
                                                  asp-controller="Courses"
                                                  asp-action="Delete"
                                                  asp-route-id="@course.Id"
                                                  onsubmit="return confirm('Delete this course? It must have no chapters.');">
                                                @Html.AntiForgeryToken()
                                                <button class="dropdown-item text-danger" type="submit">Delete course</button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
