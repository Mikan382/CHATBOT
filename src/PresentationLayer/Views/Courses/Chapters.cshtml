@model CourseChaptersViewModel
@{
    ViewData["Title"] = "Chapters";
}

<div class="card app-card table-card management-dropdown-card">
    <div class="card-body">
        <div class="page-toolbar">
            <div>
                <h4 class="card-title mb-1">@Model.Course.Code Chapters</h4>
                <div class="text-muted small">@Model.Course.Name</div>
            </div>
            <a class="btn btn-primary" asp-controller="Chapters" asp-action="Create" asp-route-courseId="@Model.Course.Id">Create Chapter</a>
        </div>

        <div class="table-responsive management-table-responsive">
        <table class="table table-sm align-middle">
            <thead>
            <tr>
                <th>Order</th>
                <th>CLO</th>
                <th>Title</th>
                <th>Summary</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Course.Chapters.Count == 0)
            {
                <tr><td colspan="5" class="text-muted small py-3">This course has no chapters yet.</td></tr>
            }
            else
            {
                @foreach (var chapter in Model.Course.Chapters)
                {
                    <tr>
                        <td>@chapter.Order</td>
                        <td>@chapter.Clo</td>
                        <td>@chapter.Title</td>
                        <td class="small">@chapter.Summary</td>
                        <td class="management-actions-cell">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        data-bs-boundary="viewport"
                                        aria-expanded="false">
                                    Actions
                                </button>
                                <div class="dropdown-menu dropdown-menu-end">
                                    <a class="dropdown-item"
                                       asp-controller="Chapters"
                                       asp-action="Edit"
                                       asp-route-id="@chapter.Id">
                                        Edit chapter
                                    </a>
                                    <div class="dropdown-divider"></div>
                                    <form method="post"
                                          asp-controller="Courses"
                                          asp-action="DeleteChapter"
                                          asp-route-id="@Model.Course.Id"
                                          asp-route-chapterId="@chapter.Id"
                                          onsubmit="return confirm('Delete this chapter? It must have no documents.');">
                                        @Html.AntiForgeryToken()
                                        <button class="dropdown-item text-danger" type="submit">Delete chapter</button>
                                    </form>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
        </div>
    </div>
</div>
