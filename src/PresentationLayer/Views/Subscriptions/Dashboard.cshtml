@using System.Globalization
@model SubscriptionDashboardViewModel
@{
    ViewData["Title"] = "Subscription Dashboard";
}

<div>
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="mb-1">Subscription Dashboard</h2>
            <div class="text-muted">VNPay revenue, active package value, and current package usage.</div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="alert alert-danger" role="alert">@Model.Error</div>
    }
    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

    <div class="subscription-dashboard-stats mb-4">
        <div class="card app-card stat-card">
            <div class="card-body">
                <div class="text-muted small">Students</div>
                <div class="stat-value">@Model.Dashboard.TotalStudents</div>
            </div>
        </div>
        <div class="card app-card stat-card">
            <div class="card-body">
                <div class="text-muted small">Active subscriptions</div>
                <div class="stat-value">@Model.Dashboard.ActiveSubscriptions</div>
            </div>
        </div>
        <div class="card app-card stat-card">
            <div class="card-body">
                <div class="text-muted small">Activations this month</div>
                <div class="stat-value">@Model.Dashboard.ActivationsThisMonth</div>
            </div>
        </div>
        <div class="card app-card stat-card">
            <div class="card-body">
                <div class="text-muted small">Revenue this month</div>
                <div class="stat-value stat-value-money">@Model.Dashboard.RevenueThisMonth.ToString("N0") <span>VND</span></div>
                <div class="text-muted small">Successful VNPay payments</div>
            </div>
        </div>
        <div class="card app-card stat-card">
            <div class="card-body">
                <div class="text-muted small">Active quota usage</div>
                <div class="stat-value">@Model.Dashboard.UsedMessages.ToString("N0")</div>
                <div class="text-muted small">
                    Accepted questions / @Model.Dashboard.FiniteMessageQuota.ToString("N0") finite quota
                    @if (Model.Dashboard.UnlimitedSubscriptions > 0) { <span>/ @Model.Dashboard.UnlimitedSubscriptions unlimited</span> }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-5">
            <div class="card app-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                        <h5 class="card-title mb-0">Payment Summary</h5>
                        <div class="text-end">
                            <div class="fw-bold">@Model.Dashboard.TotalRevenue.ToString("N0") VND</div>
                            <div class="text-muted small">All successful VNPay payments</div>
                        </div>
                    </div>
                    <dl class="subscription-summary-list mb-0">
                        <div><dt>Paid this month</dt><dd>@Model.Dashboard.PaidPaymentsThisMonth</dd></div>
                        <div><dt>Pending</dt><dd>@Model.Dashboard.PendingPayments</dd></div>
                        <div><dt>Failed this month</dt><dd>@Model.Dashboard.FailedPaymentsThisMonth</dd></div>
                        <div><dt>Active package value</dt><dd>@Model.Dashboard.ActivePackageValue.ToString("N0") VND</dd></div>
                    </dl>
                    <div class="text-muted small mt-3">
                        Active package value is operational data, not collected revenue. Revoking or cancelling access does not refund a successful payment.
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card app-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Package Distribution</h5>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Package</th>
                                <th>Status</th>
                                <th class="text-end">Active</th>
                                <th class="text-end">Active value</th>
                            </tr>
                            </thead>
                            <tbody>
                            @if (Model.Dashboard.PlanStats.Count == 0)
                            {
                                <tr><td colspan="4" class="text-muted small">No packages have been created.</td></tr>
                            }
                            else
                            {
                                @foreach (var stat in Model.Dashboard.PlanStats)
                                {
                                    <tr>
                                        <td>@stat.PlanCode - @stat.PlanName</td>
                                        <td><span class="badge @(stat.IsActive ? "text-bg-success" : "text-bg-secondary")">@(stat.IsActive ? "Active" : "Inactive")</span></td>
                                        <td class="text-end">@stat.ActiveSubscriptions</td>
                                        <td class="text-end text-nowrap">@stat.ActivePackageValue.ToString("N0") VND</td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-xl-6">
            <div class="card app-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Recent Payments</h5>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Student</th>
                                <th>Package</th>
                                <th class="text-end">Amount</th>
                                <th>Status</th>
                                <th>Time</th>
                            </tr>
                            </thead>
                            <tbody>
                            @if (Model.Dashboard.RecentPayments.Count == 0)
                            {
                                <tr><td colspan="5" class="text-muted small">No VNPay transactions yet.</td></tr>
                            }
                            else
                            {
                                @foreach (var payment in Model.Dashboard.RecentPayments)
                                {
                                    <tr>
                                        <td>
                                            <div>@payment.StudentDisplayName</div>
                                            <div class="text-muted small">@payment.StudentEmail</div>
                                        </td>
                                        <td>@payment.PlanName</td>
                                        <td class="text-end text-nowrap">@payment.Amount.ToString("N0") VND</td>
                                        <td><span class="badge payment-status payment-status-@payment.Status.ToLowerInvariant()">@payment.Status</span></td>
                                        <td class="small text-nowrap">@payment.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="card app-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Recent Activations</h5>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Student</th>
                                <th>Package</th>
                                <th>Status</th>
                                <th>Activated</th>
                                <th class="text-end">Action</th>
                            </tr>
                            </thead>
                            <tbody>
                            @if (Model.Dashboard.RecentSubscriptions.Count == 0)
                            {
                                <tr><td colspan="5" class="text-muted small">No subscription activations yet.</td></tr>
                            }
                            else
                            {
                                @foreach (var item in Model.Dashboard.RecentSubscriptions)
                                {
                                    <tr>
                                        <td>
                                            <div>@item.StudentDisplayName</div>
                                            <div class="text-muted small">@item.StudentEmail</div>
                                        </td>
                                        <td>@item.PlanName</td>
                                        <td><span class="badge subscription-status subscription-status-@item.Status.ToLowerInvariant()">@item.Status</span></td>
                                        <td class="small text-nowrap">@item.ActivatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                        <td class="text-end">
                                            @if (item.Status == "Active")
                                            {
                                                <form method="post" asp-controller="Subscriptions" asp-action="RevokeSubscription" asp-route-id="@item.Id" class="subscription-revoke-form">
                                                    @Html.AntiForgeryToken()
                                                    <button class="btn btn-sm btn-outline-danger" type="submit">Revoke</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card app-card mb-4">
        <div class="card-body">
            <h5 class="card-title">Create Package</h5>
            <form method="post" asp-controller="Subscriptions" asp-action="CreatePlan" class="subscription-plan-form">
                @Html.AntiForgeryToken()
                <input class="form-control form-control-sm" name="Code" value="@Model.CreatePlan.Code" placeholder="Code" maxlength="32" required />
                <input class="form-control form-control-sm" name="Name" value="@Model.CreatePlan.Name" placeholder="Name" maxlength="160" required />
                <input class="form-control form-control-sm" name="MonthlyPrice" value="@Model.CreatePlan.MonthlyPrice.ToString(CultureInfo.InvariantCulture)" type="number" min="0" step="1" placeholder="Price (VND)" required />
                <input class="form-control form-control-sm" name="DurationDays" value="@Model.CreatePlan.DurationDays" type="number" min="0" max="3650" title="Access duration in days (0 = no expiry)" required />
                <input class="form-control form-control-sm" name="MessageQuota" value="@Model.CreatePlan.MessageQuota" type="number" min="0" max="1000000" title="Accepted questions per activation (0 = unlimited)" placeholder="Question quota" required />
                <input class="form-control form-control-sm" name="SortOrder" value="@Model.CreatePlan.SortOrder" type="number" min="0" max="10000" title="Display order" required />
                <input class="form-control form-control-sm subscription-description-input" name="Description" value="@Model.CreatePlan.Description" placeholder="Description" maxlength="600" />
                <label class="form-check small subscription-plan-active-field">
                    @if (Model.CreatePlan.IsActive)
                    {
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                    }
                    else
                    {
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" />
                    }
                    <input type="hidden" name="IsActive" value="false" />
                    <span>Active</span>
                </label>
                <button class="btn btn-sm btn-primary" type="submit">Create</button>
            </form>
        </div>
    </div>

    <div class="card app-card">
        <div class="card-body">
            <h5 class="card-title">Manage Packages</h5>
            <div class="text-muted small mb-3">Price, duration, and quota changes apply to future activations only.</div>
            <div class="subscription-plan-editor">
                @if (Model.Dashboard.Plans.Count == 0)
                {
                    <div class="empty-state">Create a package to start managing subscriptions.</div>
                }
                else
                {
                    <div class="subscription-plan-grid subscription-plan-grid-header">
                        <div>Code</div>
                        <div>Name</div>
                        <div>Price</div>
                        <div>Days</div>
                        <div>Quota</div>
                        <div>Order</div>
                        <div>Description</div>
                        <div>Active</div>
                        <div></div>
                    </div>
                    @foreach (var plan in Model.Dashboard.Plans)
                    {
                        var failed = Model.FailedPlanUpdate?.Id == plan.Id ? Model.FailedPlanUpdate : null;
                        var code = failed?.Code ?? plan.Code;
                        var name = failed?.Name ?? plan.Name;
                        var description = failed?.Description ?? plan.Description;
                        var monthlyPrice = failed?.MonthlyPrice ?? plan.MonthlyPrice;
                        var durationDays = failed?.DurationDays ?? plan.DurationDays;
                        var messageQuota = failed?.MessageQuota ?? plan.MessageQuota;
                        var sortOrder = failed?.SortOrder ?? plan.SortOrder;
                        var isActive = failed?.IsActive ?? plan.IsActive;
                        <form method="post" asp-controller="Subscriptions" asp-action="UpdatePlan" class="subscription-plan-edit-form subscription-plan-grid">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Id" value="@plan.Id" />
                            <input class="form-control form-control-sm" name="Code" value="@code" maxlength="32" required />
                            <input class="form-control form-control-sm" name="Name" value="@name" maxlength="160" required />
                            <input class="form-control form-control-sm" name="MonthlyPrice" type="number" min="0" step="1" value="@monthlyPrice.ToString(CultureInfo.InvariantCulture)" required />
                            <input class="form-control form-control-sm" name="DurationDays" type="number" min="0" max="3650" value="@durationDays" title="Access duration in days (0 = no expiry)" required />
                            <input class="form-control form-control-sm" name="MessageQuota" type="number" min="0" max="1000000" value="@messageQuota" title="Accepted questions per activation (0 = unlimited)" required />
                            <input class="form-control form-control-sm" name="SortOrder" type="number" min="0" max="10000" value="@sortOrder" title="Display order" required />
                            <input class="form-control form-control-sm subscription-description-input" name="Description" value="@description" maxlength="600" />
                            <label class="form-check small subscription-plan-active-field">
                                @if (isActive)
                                {
                                    <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                                }
                                else
                                {
                                    <input class="form-check-input" type="checkbox" name="IsActive" value="true" />
                                }
                                <input type="hidden" name="IsActive" value="false" />
                                <span>Active</span>
                            </label>
                            <button class="btn btn-sm btn-outline-primary" type="submit">Save</button>
                        </form>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".subscription-revoke-form").forEach((form) => {
            form.addEventListener("submit", (event) => {
                const message = "Revoke this subscription? Access ends immediately and the VNPay payment is not refunded.";
                if (!confirm(message)) {
                    event.preventDefault();
                }
            });
        });
    </script>
}
