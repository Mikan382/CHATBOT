@using System.Globalization
@model SubscriptionDashboardViewModel
@{
    ViewData["Title"] = "Subscription Dashboard";
    var eligibleDefaultPlans = Model.Dashboard.Plans
        .Where(plan => plan.IsActive && plan.Price == 0)
        .ToList();
    var currentDefaultPlan = Model.Dashboard.Plans.FirstOrDefault(plan => plan.IsDefault);
}

<div>
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="mb-1">Subscription Dashboard</h2>
            <div class="text-muted">Prepaid package, VNPay payment, and Gemini token usage.</div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="alert alert-danger" role="alert">@Model.Error</div>
    }
    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

    <div class="subscription-dashboard-stats mb-4">
        <div class="card app-card stat-card">
            <div class="card-body">
                <div class="text-muted small">Students</div>
                <div class="stat-value">@Model.Dashboard.TotalStudents</div>
            </div>
        </div>
        <div class="card app-card stat-card">
            <div class="card-body">
                <div class="text-muted small">Active subscriptions</div>
                <div class="stat-value">@Model.Dashboard.ActiveSubscriptions</div>
            </div>
        </div>
        <div class="card app-card stat-card">
            <div class="card-body">
                <div class="text-muted small">Activations this month</div>
                <div class="stat-value">@Model.Dashboard.ActivationsThisMonth</div>
            </div>
        </div>
        <div class="card app-card stat-card">
            <div class="card-body">
                <div class="text-muted small">Gross revenue this month</div>
                <div class="stat-value stat-value-money">
                    @Model.Dashboard.GrossRevenueThisMonth.ToString("N0") <span>VND</span>
                </div>
                <div class="text-muted small">Successful VNPay payments</div>
            </div>
        </div>
        <div class="card app-card stat-card">
            <div class="card-body">
                <div class="text-muted small">Active token usage</div>
                <div class="stat-value">@Model.Dashboard.TotalTokensUsed.ToString("N0")</div>
                <div class="text-muted small">
                    of @Model.Dashboard.ActiveTokenQuota.ToString("N0") tokens
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-5">
            <div class="card app-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                        <h5 class="card-title mb-0">Payment Summary</h5>
                        <div class="text-end">
                            <div class="fw-bold">@Model.Dashboard.TotalGrossRevenue.ToString("N0") VND</div>
                            <div class="text-muted small">Total gross revenue</div>
                        </div>
                    </div>
                    <dl class="subscription-summary-list mb-0">
                        <div><dt>Paid this month</dt><dd>@Model.Dashboard.PaidPaymentsThisMonth</dd></div>
                        <div><dt>Pending</dt><dd>@Model.Dashboard.PendingPayments</dd></div>
                        <div><dt>Failed this month</dt><dd>@Model.Dashboard.FailedPaymentsThisMonth</dd></div>
                        <div><dt>Active package value</dt><dd>@Model.Dashboard.ActivePackageValue.ToString("N0") VND</dd></div>
                        <div><dt>Input tokens</dt><dd>@Model.Dashboard.InputTokensUsed.ToString("N0")</dd></div>
                        <div><dt>Output tokens</dt><dd>@Model.Dashboard.OutputTokensUsed.ToString("N0")</dd></div>
                    </dl>
                    <div class="text-muted small mt-3">
                        Revenue includes successful payments only. Refunds, recurring billing, and prorating are outside this demo scope.
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card app-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Package Distribution</h5>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Package</th>
                                <th>Status</th>
                                <th class="text-end">Active</th>
                                <th class="text-end">Active value</th>
                            </tr>
                            </thead>
                            <tbody>
                            @if (Model.Dashboard.PlanStats.Count == 0)
                            {
                                <tr><td colspan="4" class="text-muted small">No packages have been created.</td></tr>
                            }
                            else
                            {
                                @foreach (var stat in Model.Dashboard.PlanStats)
                                {
                                    <tr>
                                        <td>
                                            @stat.PlanCode - @stat.PlanName
                                            @if (stat.IsDefault)
                                            {
                                                <span class="badge text-bg-info ms-1">Default</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @(stat.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                                @(stat.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </td>
                                        <td class="text-end">@stat.ActiveSubscriptions</td>
                                        <td class="text-end text-nowrap">@stat.ActivePackageValue.ToString("N0") VND</td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-xl-6">
            <div class="card app-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Recent Payments</h5>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Student</th>
                                <th>Package</th>
                                <th class="text-end">Amount</th>
                                <th>Status</th>
                                <th>Time</th>
                            </tr>
                            </thead>
                            <tbody>
                            @if (Model.Dashboard.RecentPayments.Count == 0)
                            {
                                <tr><td colspan="5" class="text-muted small">No VNPay transactions yet.</td></tr>
                            }
                            else
                            {
                                @foreach (var payment in Model.Dashboard.RecentPayments)
                                {
                                    <tr>
                                        <td>
                                            <div>@payment.StudentDisplayName</div>
                                            <div class="text-muted small">@payment.StudentEmail</div>
                                        </td>
                                        <td>@payment.PlanName</td>
                                        <td class="text-end text-nowrap">@payment.Amount.ToString("N0") VND</td>
                                        <td><span class="badge payment-status payment-status-@payment.Status.ToLowerInvariant()">@payment.Status</span></td>
                                        <td class="small text-nowrap">@payment.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="card app-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Recent Activations</h5>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Student</th>
                                <th>Package</th>
                                <th>Status</th>
                                <th>Activated</th>
                                <th>Expires</th>
                            </tr>
                            </thead>
                            <tbody>
                            @if (Model.Dashboard.RecentSubscriptions.Count == 0)
                            {
                                <tr><td colspan="5" class="text-muted small">No subscription activations yet.</td></tr>
                            }
                            else
                            {
                                @foreach (var item in Model.Dashboard.RecentSubscriptions)
                                {
                                    <tr>
                                        <td>
                                            <div>@item.StudentDisplayName</div>
                                            <div class="text-muted small">@item.StudentEmail</div>
                                        </td>
                                        <td>@item.PlanName</td>
                                        <td><span class="badge subscription-status subscription-status-@item.Status.ToLowerInvariant()">@item.Status</span></td>
                                        <td class="small text-nowrap">@item.ActivatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                        <td class="small text-nowrap">@item.ExpiresAtUtc?.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card app-card mb-4">
        <div class="card-body">
            <h5 class="card-title mb-1">Create Package</h5>
            <div class="text-muted small mb-3">
                The first active package priced at 0 VND becomes the default automatically.
            </div>
            <form method="post" asp-controller="Subscriptions" asp-action="CreatePlan" class="subscription-create-form">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label small" for="createPlanCode">Code</label>
                    <input id="createPlanCode" class="form-control form-control-sm" name="Code" value="@Model.CreatePlan.Code" maxlength="32" required />
                </div>
                <div>
                    <label class="form-label small" for="createPlanName">Name</label>
                    <input id="createPlanName" class="form-control form-control-sm" name="Name" value="@Model.CreatePlan.Name" maxlength="160" required />
                </div>
                <div>
                    <label class="form-label small" for="createPlanPrice">Price (VND)</label>
                    <input id="createPlanPrice" class="form-control form-control-sm" name="Price" value="@Model.CreatePlan.Price.ToString(CultureInfo.InvariantCulture)" type="number" min="0" step="1" required />
                </div>
                <div>
                    <label class="form-label small" for="createPlanDays">Duration (days)</label>
                    <input id="createPlanDays" class="form-control form-control-sm" name="DurationDays" value="@Model.CreatePlan.DurationDays" type="number" min="1" max="3650" required />
                </div>
                <div>
                    <label class="form-label small" for="createPlanTokens">Token quota</label>
                    <input id="createPlanTokens" class="form-control form-control-sm" name="TokenQuota" value="@Model.CreatePlan.TokenQuota" type="number" min="1" max="10000000000" required />
                </div>
                <div>
                    <label class="form-label small" for="createPlanOrder">Display order</label>
                    <input id="createPlanOrder" class="form-control form-control-sm" name="SortOrder" value="@Model.CreatePlan.SortOrder" type="number" min="0" max="10000" required />
                </div>
                <div class="subscription-create-description">
                    <label class="form-label small" for="createPlanDescription">Description</label>
                    <input id="createPlanDescription" class="form-control form-control-sm" name="Description" value="@Model.CreatePlan.Description" maxlength="600" />
                </div>
                <div class="subscription-create-actions">
                    <label class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked="@Model.CreatePlan.IsActive" />
                        <input type="hidden" name="IsActive" value="false" />
                        <span class="form-check-label">Active</span>
                    </label>
                    <button class="btn btn-sm btn-primary" type="submit">Create package</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card app-card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <h5 class="card-title mb-1">Manage Packages</h5>
                    <div class="text-muted small">
                        Changes apply to future activations. Existing subscriptions keep their activation snapshot.
                    </div>
                </div>
                <span class="badge text-bg-light">@Model.Dashboard.Plans.Count package(s)</span>
            </div>

            <section class="subscription-default-panel">
                <div>
                    <div class="fw-semibold">Default package</div>
                    <div class="text-muted small">New Students receive exactly one selected active 0 VND package.</div>
                </div>
                @if (eligibleDefaultPlans.Count == 0)
                {
                    <div class="text-danger small">Create an active 0 VND package before creating Student accounts.</div>
                }
                else
                {
                    <form method="post"
                          asp-controller="Subscriptions"
                          asp-action="SetDefaultPlan"
                          class="subscription-default-form"
                          data-current-default-id="@currentDefaultPlan?.Id">
                        @Html.AntiForgeryToken()
                        <select class="form-select form-select-sm" name="planId" aria-label="Default subscription package">
                            @foreach (var plan in eligibleDefaultPlans)
                            {
                                <option value="@plan.Id" selected="@plan.IsDefault">
                                    @plan.Code - @plan.Name
                                </option>
                            }
                        </select>
                        <button class="btn btn-sm btn-outline-primary" type="submit">Set default</button>
                    </form>
                }
            </section>

            <div class="subscription-plan-editor">
                @if (Model.Dashboard.Plans.Count == 0)
                {
                    <div class="empty-state">Create an active free default package before creating Student accounts.</div>
                }
                else
                {
                    @foreach (var plan in Model.Dashboard.Plans)
                    {
                        var failed = Model.FailedPlanUpdate?.Id == plan.Id ? Model.FailedPlanUpdate : null;
                        var code = failed?.Code ?? plan.Code;
                        var name = failed?.Name ?? plan.Name;
                        var description = failed?.Description ?? plan.Description;
                        var price = failed?.Price ?? plan.Price;
                        var durationDays = failed?.DurationDays ?? plan.DurationDays;
                        var tokenQuota = failed?.TokenQuota ?? plan.TokenQuota;
                        var sortOrder = failed?.SortOrder ?? plan.SortOrder;
                        var isActive = plan.IsDefault || (failed?.IsActive ?? plan.IsActive);
                        <article class="subscription-plan-item @(plan.IsDefault ? "is-default" : "")">
                            <div class="subscription-plan-item-header">
                                <div>
                                    <strong>@plan.Code - @plan.Name</strong>
                                    <div class="text-muted small">
                                        @plan.DurationDays days / @plan.TokenQuota.ToString("N0") tokens
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    @if (plan.IsDefault)
                                    {
                                        <span class="badge text-bg-info">Default</span>
                                    }
                                    <span class="badge @(plan.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                        @(plan.IsActive ? "Active" : "Inactive")
                                    </span>
                                </div>
                            </div>
                            <form method="post" asp-controller="Subscriptions" asp-action="UpdatePlan" class="subscription-plan-edit-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Id" value="@plan.Id" />
                                <div>
                                    <label class="form-label small">Code</label>
                                    <input class="form-control form-control-sm" name="Code" value="@code" maxlength="32" required />
                                </div>
                                <div>
                                    <label class="form-label small">Name</label>
                                    <input class="form-control form-control-sm" name="Name" value="@name" maxlength="160" required />
                                </div>
                                <div>
                                    <label class="form-label small">Price (VND)</label>
                                    @if (plan.IsDefault)
                                    {
                                        <input class="form-control form-control-sm"
                                               name="Price"
                                               type="number"
                                               min="0"
                                               step="1"
                                               value="@price.ToString(CultureInfo.InvariantCulture)"
                                               readonly
                                               required />
                                    }
                                    else
                                    {
                                        <input class="form-control form-control-sm"
                                               name="Price"
                                               type="number"
                                               min="0"
                                               step="1"
                                               value="@price.ToString(CultureInfo.InvariantCulture)"
                                               required />
                                    }
                                </div>
                                <div>
                                    <label class="form-label small">Duration (days)</label>
                                    <input class="form-control form-control-sm" name="DurationDays" type="number" min="1" max="3650" value="@durationDays" required />
                                </div>
                                <div>
                                    <label class="form-label small">Token quota</label>
                                    <input class="form-control form-control-sm" name="TokenQuota" type="number" min="1" max="10000000000" value="@tokenQuota" required />
                                </div>
                                <div>
                                    <label class="form-label small">Display order</label>
                                    <input class="form-control form-control-sm" name="SortOrder" type="number" min="0" max="10000" value="@sortOrder" required />
                                </div>
                                <div class="subscription-plan-description">
                                    <label class="form-label small">Description</label>
                                    <input class="form-control form-control-sm" name="Description" value="@description" maxlength="600" />
                                </div>
                                <div class="subscription-plan-footer">
                                    @if (plan.IsDefault)
                                    {
                                        <input type="hidden" name="IsActive" value="true" />
                                        <div class="text-muted small">Choose another default package before changing this package's price or status.</div>
                                    }
                                    else
                                    {
                                        <label class="form-check form-switch mb-0">
                                            <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked="@isActive" />
                                            <input type="hidden" name="IsActive" value="false" />
                                            <span class="form-check-label">Active</span>
                                        </label>
                                    }
                                    <button class="btn btn-sm btn-outline-primary" type="submit">Save changes</button>
                                </div>
                            </form>
                        </article>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const defaultForm = document.querySelector(".subscription-default-form");
        if (defaultForm) {
            const select = defaultForm.querySelector("select");
            const button = defaultForm.querySelector("button[type='submit']");
            const currentDefaultId = defaultForm.dataset.currentDefaultId || "";
            const updateDefaultButton = () => {
                const unchanged = select.value === currentDefaultId;
                button.disabled = unchanged;
                button.textContent = unchanged ? "Current default" : "Set default";
            };
            select.addEventListener("change", updateDefaultButton);
            updateDefaultButton();
        }
    </script>
}
