@using System.Globalization
@model SubscriptionDashboardViewModel
@{
    ViewData["Title"] = "Subscription Dashboard";
    var eligibleDefaultPlans = Model.Dashboard.Plans
        .Where(plan => plan.IsActive && plan.Price == 0)
        .ToList();
    var currentDefaultPlan = Model.Dashboard.Plans.FirstOrDefault(plan => plan.IsDefault);
    var d = Model.Dashboard;
    string PeriodLink(int p) => Url.Action("Dashboard", new { period = p == 30 ? (int?)null : p })!;
    string PeriodLabel(int p) => p switch { 7 => "7 days", 0 => "This month", _ => "30 days" };
    bool IsActive(int p) => Model.PeriodDays == p;
}

<div>
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="mb-1">Subscription Dashboard</h2>
            <div class="text-muted">Prepaid package, VNPay payment, and Gemini token usage.</div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="alert alert-danger" role="alert">@Model.Error</div>
    }
    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-3" id="dashboardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview-pane"
                    type="button" role="tab" aria-controls="overview-pane" aria-selected="true">Overview</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="packages-tab" data-bs-toggle="tab" data-bs-target="#packages-pane"
                    type="button" role="tab" aria-controls="packages-pane" aria-selected="false">Manage Packages</button>
        </li>
    </ul>

    <div class="tab-content" id="dashboardTabContent">
        <!-- ============================================================ -->
        <!-- TAB 1: OVERVIEW -->
        <!-- ============================================================ -->
        <div class="tab-pane fade show active" id="overview-pane" role="tabpanel" aria-labelledby="overview-tab">

            <!-- Time filter -->
            <div class="mb-3 d-flex flex-wrap align-items-center gap-3">
                <div class="btn-group btn-group-sm" role="group" aria-label="Time period filter">
                    @foreach (var p in new[] { 7, 30, 0 })
                    {
                        <a href="@PeriodLink(p)" class="btn @(IsActive(p) && !Model.StartDate.HasValue && !Model.EndDate.HasValue ? "btn-primary" : "btn-outline-secondary")">@PeriodLabel(p)</a>
                    }
                </div>
                <form method="get" asp-controller="Subscriptions" asp-action="Dashboard" class="d-flex align-items-center gap-2">
                    <input type="date" class="form-control form-control-sm" name="startDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" placeholder="From Date" />
                    <span class="text-muted small">to</span>
                    <input type="date" class="form-control form-control-sm" name="endDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" placeholder="To Date" />
                    <button type="submit" class="btn btn-sm btn-primary">Filter</button>
                    @if (Model.StartDate.HasValue || Model.EndDate.HasValue)
                    {
                        <a asp-controller="Subscriptions" asp-action="Dashboard" class="btn btn-sm btn-outline-secondary">Reset</a>
                    }
                </form>
            </div>

            <!-- KPI Cards -->
            <div class="subscription-dashboard-stats mb-4">
                <div class="card app-card stat-card kpi-clickable" id="kpi-active-subs" role="button"
                     data-bs-toggle="modal" data-bs-target="#activeSubsModal" title="View active subscription details">
                    <div class="card-body">
                        <div class="text-muted small">Active subscriptions</div>
                        <div class="stat-value">@d.ActiveSubscriptions</div>
                        <div class="small mt-1"><a href="#" data-bs-toggle="modal" data-bs-target="#activeSubsModal">View details</a></div>
                    </div>
                </div>
                <div class="card app-card stat-card">
                    <div class="card-body">
                        <div class="text-muted small">Paid activations</div>
                        <div class="stat-value">@d.PaidActivations</div>
                        <div class="text-muted small">In selected period</div>
                    </div>
                </div>
                <div class="card app-card stat-card">
                    <div class="card-body">
                        <div class="text-muted small">Revenue</div>
                        <div class="stat-value stat-value-money">
                            @d.Revenue.ToString("N0") <span>VND</span>
                        </div>
                        <div class="text-muted small">Successful payments</div>
                    </div>
                </div>
                <div class="card app-card stat-card">
                    <div class="card-body">
                        <div class="text-muted small">Token usage</div>
                        <div class="stat-value" style="font-size:22px">
                            @d.TotalTokensUsed.ToString("N0") / @d.ActiveTokenQuota.ToString("N0")
                        </div>
                        <div class="progress mt-1" style="height:6px">
                            <div class="progress-bar @(d.TokenUtilization >= 95 ? "bg-danger" : d.TokenUtilization >= 80 ? "bg-warning" : "bg-success")"
                                 role="progressbar" style="width:@(Math.Min(100, d.TokenUtilization))%"
                                 aria-valuenow="@d.TokenUtilization" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="text-muted small mt-1">@d.TokenUtilization% utilization</div>
                    </div>
                </div>
                <div class="card app-card stat-card kpi-clickable" id="kpi-needs-attention" role="button" title="View issues">
                    <div class="card-body">
                        <div class="text-muted small">Needs attention</div>
                        <div class="stat-value @(d.NeedsAttentionCount > 0 ? "text-warning" : "")">@d.NeedsAttentionCount</div>
                        @if (d.NeedsAttentionCount > 0)
                        {
                            <div class="small mt-1"><a href="#needs-attention" class="scroll-to-attention">View issues</a></div>
                        }
                        else
                        {
                            <div class="text-muted small">All clear</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Trend Chart -->
            <div class="card app-card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">Trend</h5>
                        <div class="btn-group btn-group-sm" role="group">
                            <button class="btn btn-primary btn-sm" id="chartModeRevenue" type="button">Revenue</button>
                            <button class="btn btn-outline-secondary btn-sm" id="chartModeActivations" type="button">Activations</button>
                        </div>
                    </div>
                    <div style="position:relative;height:260px">
                        <canvas id="trendChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Package Performance -->
            <div class="card app-card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Package Performance</h5>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Package</th>
                                <th class="text-end">Active users</th>
                                <th class="text-end">Paid activations</th>
                                <th class="text-end">Revenue</th>
                                <th class="text-end">Token used</th>
                                <th class="text-end">Token quota</th>
                                <th class="text-end">Utilization</th>
                            </tr>
                            </thead>
                            <tbody>
                            @if (d.PackagePerformance.Count == 0)
                            {
                                <tr><td colspan="7" class="text-muted small">No packages have been created.</td></tr>
                            }
                            else
                            {
                                @foreach (var pkg in d.PackagePerformance)
                                {
                                    <tr>
                                        <td>@pkg.PackageCode — @pkg.PackageName</td>
                                        <td class="text-end">@pkg.ActiveUsers</td>
                                        <td class="text-end">@pkg.PaidActivations</td>
                                        <td class="text-end text-nowrap">@pkg.Revenue.ToString("N0") VND</td>
                                        <td class="text-end">@pkg.TokenUsed.ToString("N0")</td>
                                        <td class="text-end">@pkg.TokenQuota.ToString("N0")</td>
                                        <td class="text-end">
                                            @if (pkg.Utilization.HasValue)
                                            {
                                                <span>@pkg.Utilization.Value%</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                                var totalActiveUsers = d.PackagePerformance.Sum(p => p.ActiveUsers);
                                var totalPaidAct = d.PackagePerformance.Sum(p => p.PaidActivations);
                                var totalRev = d.PackagePerformance.Sum(p => p.Revenue);
                                var totalTkUsed = d.PackagePerformance.Sum(p => p.TokenUsed);
                                var totalTkQuota = d.PackagePerformance.Sum(p => p.TokenQuota);
                                var totalUtil = totalTkQuota > 0 ? Math.Round((decimal)totalTkUsed / totalTkQuota * 100, 1) : (decimal?)null;
                                <tr class="fw-bold" style="border-top:2px solid #d8dee8">
                                    <td>Total</td>
                                    <td class="text-end">@totalActiveUsers</td>
                                    <td class="text-end">@totalPaidAct</td>
                                    <td class="text-end text-nowrap">@totalRev.ToString("N0") VND</td>
                                    <td class="text-end">@totalTkUsed.ToString("N0")</td>
                                    <td class="text-end">@totalTkQuota.ToString("N0")</td>
                                    <td class="text-end">@(totalUtil.HasValue ? $"{totalUtil.Value}%" : "—")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Needs Attention -->
            <div id="needs-attention" class="mb-4">
                <h5 class="mb-3">Needs Attention</h5>
                <div class="row g-3">
                    <!-- Expiring in 7 days -->
                    <div class="col-xl-4">
                        <div class="card app-card h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="card-title mb-0">
                                        <span class="badge text-bg-warning me-1">@d.ExpiringSubscriptionsTotal</span>
                                        Expiring in 7 days
                                    </h6>
                                </div>
                                @if (d.ExpiringSubscriptions.Count == 0)
                                {
                                    <div class="text-muted small">No subscriptions expiring soon.</div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0">
                                            <thead><tr><th>Student</th><th>Package</th><th>Expires</th><th>Days left</th></tr></thead>
                                            <tbody>
                                            @foreach (var item in d.ExpiringSubscriptions)
                                            {
                                                <tr>
                                                    <td>
                                                        <div>@item.StudentName</div>
                                                        <div class="text-muted small">@item.StudentEmail</div>
                                                    </td>
                                                    <td>@item.PackageName</td>
                                                    <td class="small text-nowrap">@item.ExpiresAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                                    <td>
                                                        <span class="badge @(item.DaysLeft <= 2 ? "text-bg-danger" : "text-bg-warning")">
                                                            @item.DaysLeft day(s)
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                    @if (d.ExpiringSubscriptionsTotal > 5)
                                    {
                                        <div class="text-end mt-2">
                                            <a href="#" class="small" data-bs-toggle="modal" data-bs-target="#activeSubsModal">View all</a>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Failed Payments -->
                    <div class="col-xl-4">
                        <div class="card app-card h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="card-title mb-0">
                                        <span class="badge text-bg-danger me-1">@d.FailedPaymentsTotal</span>
                                        Failed payments
                                    </h6>
                                </div>
                                @if (d.FailedPayments.Count == 0)
                                {
                                    <div class="text-muted small">No failed payments in this period.</div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0">
                                            <thead><tr><th>Student</th><th>Package</th><th class="text-end">Amount</th><th>Failed at</th></tr></thead>
                                            <tbody>
                                            @foreach (var item in d.FailedPayments)
                                            {
                                                <tr>
                                                    <td>
                                                        <div>@item.StudentName</div>
                                                        <div class="text-muted small">@item.StudentEmail</div>
                                                    </td>
                                                    <td>@item.PackageName</td>
                                                    <td class="text-end text-nowrap">@item.Amount.ToString("N0") VND</td>
                                                    <td class="small text-nowrap">@item.FailedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Users near token limit -->
                    <div class="col-xl-4">
                        <div class="card app-card h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="card-title mb-0">
                                        <span class="badge @(d.UsersNearTokenLimit.Count > 0 ? "text-bg-warning" : "text-bg-secondary") me-1">@d.UsersNearTokenLimit.Count</span>
                                        Users near token limit
                                    </h6>
                                </div>
                                @if (d.UsersNearTokenLimit.Count == 0)
                                {
                                    <div class="text-muted small">No users near token limit.</div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0">
                                            <thead>
                                            <tr><th>Student</th><th>Package</th><th>Usage</th><th>Utilization</th></tr>
                                            </thead>
                                            <tbody>
                                            @foreach (var item in d.UsersNearTokenLimit)
                                            {
                                                <tr>
                                                    <td>
                                                        <div>@item.StudentName</div>
                                                        <div class="text-muted small">@item.StudentEmail</div>
                                                    </td>
                                                    <td>@item.PackageName</td>
                                                    <td class="small text-nowrap">
                                                        @item.TokensUsed.ToString("N0") / @item.TokenQuota.ToString("N0")
                                                        <div class="text-muted">@item.TokensRemaining.ToString("N0") remaining</div>
                                                    </td>
                                                    <td>
                                                        <div class="progress" style="height:6px;min-width:60px">
                                                            <div class="progress-bar @(item.Utilization >= 95 ? "bg-danger" : "bg-warning")"
                                                                 style="width:@(Math.Min(100, item.Utilization))%"></div>
                                                        </div>
                                                        <div class="small mt-1">@item.Utilization%</div>
                                                    </td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="row g-3 mb-4">
                <div class="col-xl-6">
                    <div class="card app-card h-100">
                        <div class="card-body">
                            <h5 class="card-title">Recent Payments</h5>
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead>
                                    <tr>
                                        <th>Student</th>
                                        <th>Package</th>
                                        <th class="text-end">Amount</th>
                                        <th>Status</th>
                                        <th>Time</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @if (d.RecentPayments.Count == 0)
                                    {
                                        <tr><td colspan="5" class="text-muted small">No VNPay transactions yet.</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var payment in d.RecentPayments)
                                        {
                                            <tr>
                                                <td>
                                                    <div>@payment.StudentDisplayName</div>
                                                    <div class="text-muted small">@payment.StudentEmail</div>
                                                </td>
                                                <td>@payment.PlanName</td>
                                                <td class="text-end text-nowrap">@payment.Amount.ToString("N0") VND</td>
                                                <td><span class="badge payment-status payment-status-@payment.Status.ToLowerInvariant()">@payment.Status</span></td>
                                                <td class="small text-nowrap">@payment.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                            </tr>
                                        }
                                    }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-6">
                    <div class="card app-card h-100">
                        <div class="card-body">
                            <h5 class="card-title">Recent Activations</h5>
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead>
                                    <tr>
                                        <th>Student</th>
                                        <th>Package</th>
                                        <th>Status</th>
                                        <th>Activated</th>
                                        <th>Expires</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @if (d.RecentSubscriptions.Count == 0)
                                    {
                                        <tr><td colspan="5" class="text-muted small">No subscription activations yet.</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var item in d.RecentSubscriptions)
                                        {
                                            <tr>
                                                <td>
                                                    <div>@item.StudentDisplayName</div>
                                                    <div class="text-muted small">@item.StudentEmail</div>
                                                </td>
                                                <td>@item.PlanName</td>
                                                <td><span class="badge subscription-status subscription-status-@item.Status.ToLowerInvariant()">@item.Status</span></td>
                                                <td class="small text-nowrap">@item.ActivatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                                <td class="small text-nowrap">@item.ExpiresAtUtc?.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                            </tr>
                                        }
                                    }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ============================================================ -->
        <!-- TAB 2: MANAGE PACKAGES -->
        <!-- ============================================================ -->
        <div class="tab-pane fade" id="packages-pane" role="tabpanel" aria-labelledby="packages-tab">

            <!-- Default package panel -->
            <section class="subscription-default-panel mb-3">
                <div>
                    <div class="fw-semibold">Default package</div>
                    <div class="text-muted small">New Students receive exactly one selected active 0 VND package.</div>
                </div>
                @if (eligibleDefaultPlans.Count == 0)
                {
                    <div class="text-danger small">Create an active 0 VND package before creating Student accounts.</div>
                }
                else if (eligibleDefaultPlans.Count == 1 && eligibleDefaultPlans[0].IsDefault)
                {
                    var onlyPlan = eligibleDefaultPlans[0];
                    <div class="d-flex align-items-center flex-wrap gap-2">
                        <span class="badge text-bg-info">@onlyPlan.Code — @onlyPlan.Name</span>
                        <span class="text-muted small">Only active 0 VND package, so it is the default. Create another 0 VND package to switch.</span>
                    </div>
                }
                else
                {
                    <form method="post"
                          asp-controller="Subscriptions"
                          asp-action="SetDefaultPlan"
                          class="subscription-default-form"
                          data-current-default-id="@currentDefaultPlan?.Id">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="period" value="@Model.PeriodDays" />
                        <select class="form-select form-select-sm" name="planId" aria-label="Default subscription package">
                            @foreach (var plan in eligibleDefaultPlans)
                            {
                                <option value="@plan.Id" selected="@plan.IsDefault">
                                    @plan.Code - @plan.Name
                                </option>
                            }
                        </select>
                        <button class="btn btn-sm btn-outline-primary" type="submit">Set default</button>
                    </form>
                }
            </section>

            <!-- Create package button -->
            <div class="mb-3">
                <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#packageModal"
                        id="btnCreatePackage">
                    Create package
                </button>
                <span class="text-muted small ms-2">@Model.Dashboard.Plans.Count package(s)</span>
            </div>

            <!-- Package table -->
            <div class="card app-card">
                <div class="card-body">
                    <div class="text-muted small mb-2">
                        Changes apply to future activations. Existing subscriptions keep their activation snapshot.
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Package</th>
                                <th class="text-end">Price</th>
                                <th class="text-end">Duration</th>
                                <th class="text-end">Token quota</th>
                                <th class="text-end">Active users</th>
                                <th>Status</th>
                                <th>Default</th>
                                <th>Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            @if (Model.Dashboard.Plans.Count == 0)
                            {
                                <tr><td colspan="8" class="text-muted small">Create an active free default package before creating Student accounts.</td></tr>
                            }
                            else
                            {
                                @foreach (var plan in Model.Dashboard.Plans)
                                {
                                    var planStats = d.PlanStats.FirstOrDefault(s => s.PlanId == plan.Id);
                                    <tr>
                                        <td>
                                            <strong>@plan.Code</strong> — @plan.Name
                                        </td>
                                        <td class="text-end text-nowrap">@plan.Price.ToString("N0") VND</td>
                                        <td class="text-end">@plan.DurationDays days</td>
                                        <td class="text-end">@plan.TokenQuota.ToString("N0")</td>
                                        <td class="text-end">@(planStats?.ActiveSubscriptions ?? 0)</td>
                                        <td>
                                            <span class="badge @(plan.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                                @(plan.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </td>
                                        <td>
                                            @if (plan.IsDefault)
                                            {
                                                <span class="badge text-bg-info">Default</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary edit-package-btn"
                                                    data-plan-id="@plan.Id"
                                                    data-plan-code="@plan.Code"
                                                    data-plan-name="@plan.Name"
                                                    data-plan-description="@plan.Description"
                                                    data-plan-price="@plan.Price.ToString(CultureInfo.InvariantCulture)"
                                                    data-plan-duration="@plan.DurationDays"
                                                    data-plan-tokens="@plan.TokenQuota"
                                                    data-plan-order="@plan.SortOrder"
                                                    data-plan-active="@plan.IsActive.ToString().ToLowerInvariant()"
                                                    data-plan-default="@plan.IsDefault.ToString().ToLowerInvariant()"
                                                    data-plan-active-users="@(planStats?.ActiveSubscriptions ?? 0)"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#packageModal">
                                                Edit
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Active Subscriptions Modal -->
<div class="modal fade" id="activeSubsModal" tabindex="-1" aria-labelledby="activeSubsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="activeSubsModalLabel">Active Subscriptions</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <input type="text" class="form-control form-control-sm" id="activeSubsSearch"
                           placeholder="Search by name or email..." />
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0" id="activeSubsTable">
                        <thead>
                        <tr>
                            <th>Student</th>
                            <th>Email</th>
                            <th>Package</th>
                            <th class="text-end">Used tokens</th>
                            <th class="text-end">Token quota</th>
                            <th class="text-end">Remaining</th>
                            <th class="text-end">Utilization</th>
                            <th>Activated at</th>
                            <th>Expires at</th>
                        </tr>
                        </thead>
                        <tbody id="activeSubsBody">
                            <tr><td colspan="9" class="text-muted small text-center">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Package Create/Edit Modal -->
<div class="modal fade" id="packageModal" tabindex="-1" aria-labelledby="packageModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" id="packageForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="period" value="@Model.PeriodDays" />
                <input type="hidden" name="Id" id="pkgId" />
                <div class="modal-header">
                    <h5 class="modal-title" id="packageModalLabel">Create Package</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="packageModalError" class="alert alert-danger d-none" role="alert"></div>
                    <div class="mb-2">
                        <label class="form-label small" for="pkgCode">Code</label>
                        <input id="pkgCode" class="form-control form-control-sm" name="Code" maxlength="32" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small" for="pkgName">Name</label>
                        <input id="pkgName" class="form-control form-control-sm" name="Name" maxlength="160" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small" for="pkgPrice">Price (VND)</label>
                        <input id="pkgPrice" class="form-control form-control-sm" name="Price" type="number" min="0" step="1" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small" for="pkgDuration">Duration (days)</label>
                        <input id="pkgDuration" class="form-control form-control-sm" name="DurationDays" type="number" min="1" max="3650" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small" for="pkgTokens">Token quota</label>
                        <input id="pkgTokens" class="form-control form-control-sm" name="TokenQuota" type="number" min="1" max="10000000000" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small" for="pkgOrder">Display order</label>
                        <input id="pkgOrder" class="form-control form-control-sm" name="SortOrder" type="number" min="0" max="10000" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small" for="pkgDescription">Description</label>
                        <input id="pkgDescription" class="form-control form-control-sm" name="Description" maxlength="600" />
                    </div>
                    <div class="mb-2" id="pkgActiveGroup">
                        <label class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" name="IsActive" value="true" id="pkgIsActive" checked />
                            @* A disabled checkbox posts nothing, so this fallback carries the value for the default package. *@
                            <input type="hidden" name="IsActive" value="false" id="pkgIsActiveFallback" />
                            <span class="form-check-label">Active</span>
                        </label>
                    </div>
                    <div id="pkgDeactivateWarning" class="alert alert-warning small d-none">
                        Existing subscriptions will remain active until expiration. The package will only be unavailable for future purchases.
                    </div>
                    <div id="pkgDefaultNote" class="text-muted small d-none">
                        Choose another default package before changing this package's price or status.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-primary" id="pkgSubmitBtn">Create package</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        // ===== Trend chart data from server =====
        const trendData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.Trend, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
        const trendLabels = trendData.map(d => d.date);
        const trendRevenue = trendData.map(d => d.revenue);
        const trendActivations = trendData.map(d => d.paidActivations);

        let currentMode = "revenue";
        const ctx = document.getElementById("trendChart").getContext("2d");
        const chart = new Chart(ctx, {
            type: "bar",
            data: {
                labels: trendLabels,
                datasets: [{
                    label: "Revenue (VND)",
                    data: trendRevenue,
                    backgroundColor: "rgba(37, 99, 235, 0.6)",
                    borderColor: "rgba(37, 99, 235, 1)",
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true },
                    x: { grid: { display: false } }
                }
            }
        });

        function setChartMode(mode) {
            currentMode = mode;
            chart.data.datasets[0].label = mode === "revenue" ? "Revenue (VND)" : "Paid Activations";
            chart.data.datasets[0].data = mode === "revenue" ? trendRevenue : trendActivations;
            chart.data.datasets[0].backgroundColor = mode === "revenue"
                ? "rgba(37, 99, 235, 0.6)"
                : "rgba(22, 163, 74, 0.6)";
            chart.data.datasets[0].borderColor = mode === "revenue"
                ? "rgba(37, 99, 235, 1)"
                : "rgba(22, 163, 74, 1)";
            chart.update();
            document.getElementById("chartModeRevenue").className =
                "btn btn-sm " + (mode === "revenue" ? "btn-primary" : "btn-outline-secondary");
            document.getElementById("chartModeActivations").className =
                "btn btn-sm " + (mode === "activations" ? "btn-primary" : "btn-outline-secondary");
        }

        document.getElementById("chartModeRevenue").addEventListener("click", () => setChartMode("revenue"));
        document.getElementById("chartModeActivations").addEventListener("click", () => setChartMode("activations"));

        if (trendData.length === 0) {
            const noDataMsg = document.createElement("div");
            noDataMsg.className = "text-muted small text-center";
            noDataMsg.style.paddingTop = "100px";
            noDataMsg.textContent = "No revenue data for the selected period.";
            document.getElementById("trendChart").parentNode.appendChild(noDataMsg);
        }

        // ===== Scroll to needs attention =====
        document.querySelectorAll(".scroll-to-attention").forEach(link => {
            link.addEventListener("click", e => {
                e.preventDefault();
                document.getElementById("needs-attention").scrollIntoView({ behavior: "smooth" });
            });
        });
        document.getElementById("kpi-needs-attention")?.addEventListener("click", () => {
            document.getElementById("needs-attention").scrollIntoView({ behavior: "smooth" });
        });

        // ===== Active subscriptions modal =====
        const activeSubsModal = document.getElementById("activeSubsModal");
        let activeSubsLoaded = false;
        let activeSubsData = [];

        activeSubsModal.addEventListener("show.bs.modal", async () => {
            if (activeSubsLoaded) return;
            try {
                const response = await fetch("@Url.Action("ActiveSubscriptionDetails")");
                activeSubsData = await response.json();
                renderActiveSubsTable(activeSubsData);
                activeSubsLoaded = true;
            } catch {
                document.getElementById("activeSubsBody").innerHTML =
                    '<tr><td colspan="9" class="text-danger small text-center">Failed to load data.</td></tr>';
            }
        });

        function renderActiveSubsTable(data) {
            const tbody = document.getElementById("activeSubsBody");
            if (data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" class="text-muted small text-center">No active subscriptions.</td></tr>';
                return;
            }
            tbody.innerHTML = data.map(s => {
                const utilClass = s.utilization >= 95 ? "bg-danger" : s.utilization >= 80 ? "bg-warning" : "bg-success";
                const expStr = s.expiresAtUtc ? new Date(s.expiresAtUtc).toISOString().replace("T", " ").slice(0, 16) + " UTC" : "—";
                const actStr = new Date(s.activatedAtUtc).toISOString().replace("T", " ").slice(0, 16) + " UTC";
                return `<tr>
                    <td>${esc(s.studentName)}</td>
                    <td class="small">${esc(s.studentEmail)}</td>
                    <td>${esc(s.packageCode)} — ${esc(s.packageName)}</td>
                    <td class="text-end">${num(s.tokensUsed)}</td>
                    <td class="text-end">${num(s.tokenQuota)}</td>
                    <td class="text-end">${num(s.tokensRemaining)}</td>
                    <td class="text-end">
                        <div class="progress" style="height:5px;min-width:50px">
                            <div class="progress-bar ${utilClass}" style="width:${Math.min(100, s.utilization)}%"></div>
                        </div>
                        <div class="small">${s.utilization}%</div>
                    </td>
                    <td class="small text-nowrap">${actStr}</td>
                    <td class="small text-nowrap">${expStr}</td>
                </tr>`;
            }).join("");
        }

        document.getElementById("activeSubsSearch").addEventListener("input", e => {
            const q = e.target.value.toLowerCase();
            const filtered = activeSubsData.filter(s =>
                s.studentName.toLowerCase().includes(q) || s.studentEmail.toLowerCase().includes(q));
            renderActiveSubsTable(filtered);
        });

        function esc(str) { const d = document.createElement("div"); d.textContent = str; return d.innerHTML; }
        function num(n) { return n.toLocaleString(); }

        // ===== Package modal =====
        const packageModal = document.getElementById("packageModal");
        const packageForm = document.getElementById("packageForm");
        const createAction = "@Url.Action("CreatePlan")";
        const updateAction = "@Url.Action("UpdatePlan")";

        document.getElementById("btnCreatePackage").addEventListener("click", () => {
            packageForm.action = createAction;
            document.getElementById("packageModalLabel").textContent = "Create Package";
            document.getElementById("pkgSubmitBtn").textContent = "Create package";
            document.getElementById("pkgId").value = "";
            document.getElementById("pkgCode").value = "";
            document.getElementById("pkgCode").readOnly = false;
            document.getElementById("pkgName").value = "";
            document.getElementById("pkgPrice").value = "0";
            document.getElementById("pkgDuration").value = "30";
            document.getElementById("pkgTokens").value = "50000";
            document.getElementById("pkgOrder").value = "100";
            document.getElementById("pkgDescription").value = "";
            document.getElementById("pkgIsActive").checked = true;
            document.getElementById("pkgIsActive").disabled = false;
            document.getElementById("pkgIsActiveFallback").value = "false";
            document.getElementById("pkgPrice").readOnly = false;
            document.getElementById("pkgActiveGroup").classList.remove("d-none");
            document.getElementById("pkgDefaultNote").classList.add("d-none");
            document.getElementById("pkgDeactivateWarning").classList.add("d-none");
            document.getElementById("packageModalError").classList.add("d-none");
        });

        document.querySelectorAll(".edit-package-btn").forEach(btn => {
            btn.addEventListener("click", () => {
                packageForm.action = updateAction;
                document.getElementById("packageModalLabel").textContent = "Edit Package";
                document.getElementById("pkgSubmitBtn").textContent = "Save changes";
                document.getElementById("pkgId").value = btn.dataset.planId;
                document.getElementById("pkgCode").value = btn.dataset.planCode;
                document.getElementById("pkgCode").readOnly = true;
                document.getElementById("pkgName").value = btn.dataset.planName;
                document.getElementById("pkgPrice").value = btn.dataset.planPrice;
                document.getElementById("pkgDuration").value = btn.dataset.planDuration;
                document.getElementById("pkgTokens").value = btn.dataset.planTokens;
                document.getElementById("pkgOrder").value = btn.dataset.planOrder;
                document.getElementById("pkgDescription").value = btn.dataset.planDescription;

                const isDefault = btn.dataset.planDefault === "true";
                const isActive = btn.dataset.planActive === "true";
                const activeUsers = parseInt(btn.dataset.planActiveUsers || "0");

                document.getElementById("pkgIsActive").checked = isActive;
                document.getElementById("pkgIsActive").disabled = isDefault;
                // The default package keeps its active state; the disabled checkbox
                // posts nothing, so the fallback has to carry "true" instead of "false".
                document.getElementById("pkgIsActiveFallback").value = isDefault ? "true" : "false";
                document.getElementById("pkgDefaultNote").classList.toggle("d-none", !isDefault);
                document.getElementById("pkgPrice").readOnly = isDefault;

                // Show deactivate warning if toggling off active with users
                const warnEl = document.getElementById("pkgDeactivateWarning");
                warnEl.classList.add("d-none");

                document.getElementById("pkgIsActive").addEventListener("change", function handler() {
                    if (!this.checked && activeUsers > 0) {
                        warnEl.classList.remove("d-none");
                    } else {
                        warnEl.classList.add("d-none");
                    }
                });

                document.getElementById("packageModalError").classList.add("d-none");
            });
        });

        // Disable submit during save
        packageForm.addEventListener("submit", function() {
            const btn = document.getElementById("pkgSubmitBtn");
            btn.disabled = true;
            btn.textContent = "Saving...";
        });

        // Default package form
        const defaultForm = document.querySelector(".subscription-default-form");
        if (defaultForm) {
            const select = defaultForm.querySelector("select");
            const button = defaultForm.querySelector("button[type='submit']");
            const currentDefaultId = defaultForm.dataset.currentDefaultId || "";
            const updateDefaultButton = () => {
                const unchanged = select.value === currentDefaultId;
                button.disabled = unchanged;
                button.textContent = unchanged ? "Current default" : "Set default";
            };
            select.addEventListener("change", updateDefaultButton);
            updateDefaultButton();

            defaultForm.addEventListener("submit", function(e) {
                if (!confirm("Are you sure you want to change the default package?")) {
                    e.preventDefault();
                }
            });
        }

        // ===== Remember active tab =====
        const tabParam = new URLSearchParams(window.location.search).get("tab");
        if (tabParam === "packages") {
            const packagesTab = document.getElementById("packages-tab");
            if (packagesTab) new bootstrap.Tab(packagesTab).show();
        }

        // Show packages tab if there's a failedPlanUpdate error
        @if (Model.FailedPlanUpdate != null || (!string.IsNullOrWhiteSpace(Model.Error) && Model.Error.Contains("package")))
        {
            <text>
            {
                const packagesTab = document.getElementById("packages-tab");
                if (packagesTab) new bootstrap.Tab(packagesTab).show();
            }
            </text>
        }
    </script>
}
