@model StudentSubscriptionViewModel
@{
    ViewData["Title"] = "My Subscription";
    var hasPaidPackage = Model.CurrentSubscription is { IsFreePackage: false };
}

<div>
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="mb-1">My Subscription</h2>
            <div class="text-muted">Prepaid course-assistant access with VNPay sandbox payment.</div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-4">
            <div class="card app-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Current Package</h5>
                    @if (Model.CurrentSubscription is null)
                    {
                        <div class="text-muted small">
                            No package is available. Ask an Admin to configure an active default package.
                        </div>
                    }
                    else
                    {
                        var current = Model.CurrentSubscription;
                        var usagePercent = Math.Min(
                            100,
                            (int)Math.Round(current.TotalTokensUsed * 100d / current.TokenQuota));
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <div class="subscription-current-name">@current.PlanName</div>
                            @if (current.IsFreePackage)
                            {
                                <span class="badge text-bg-info">Free</span>
                            }
                        </div>
                        <div class="text-muted small mb-3">@current.PlanCode / @current.Status</div>

                        <dl class="subscription-summary-list mb-3">
                            <div><dt>Price paid</dt><dd>@current.PriceAtActivation.ToString("N0") VND</dd></div>
                            <div><dt>Token quota</dt><dd>@current.TokenQuota.ToString("N0")</dd></div>
                            <div><dt>Tokens used</dt><dd>@current.TotalTokensUsed.ToString("N0")</dd></div>
                            <div><dt>Input / output</dt><dd>@current.InputTokensUsed.ToString("N0") / @current.OutputTokensUsed.ToString("N0")</dd></div>
                        </dl>

                        <div class="progress mb-2" style="height: 8px;" aria-label="Token usage">
                            <div class="progress-bar" role="progressbar" style="width: @usagePercent%"
                                 aria-valuenow="@usagePercent" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="small mb-1">
                            Started: @current.StartedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC
                        </div>
                        <div class="small">
                            Expires: @current.ExpiresAtUtc?.ToString("yyyy-MM-dd HH:mm") UTC
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            @if (Model.AvailablePlans.Count == 0)
            {
                <div class="empty-state">No subscription packages are currently available.</div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var plan in Model.AvailablePlans)
                    {
                        var isCurrent = Model.CurrentSubscription?.PlanId == plan.Id;
                        <div class="col-md-4">
                            <div class="card app-card h-100 subscription-plan-card">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <h5 class="card-title mb-1">@plan.Name</h5>
                                        <div class="d-flex gap-1">
                                            @if (plan.IsDefault)
                                            {
                                                <span class="badge text-bg-info">Default</span>
                                            }
                                            @if (isCurrent)
                                            {
                                                <span class="badge text-bg-success">Current</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="subscription-price">@plan.Price.ToString("N0") VND</div>
                                    <div class="text-muted small mb-3">
                                        @plan.DurationDays days / @plan.TokenQuota.ToString("N0") tokens
                                    </div>
                                    <p class="small flex-grow-1">@plan.Description</p>

                                    @if (isCurrent)
                                    {
                                        <button class="btn btn-outline-secondary w-100" type="button" disabled>Current package</button>
                                    }
                                    else if (plan.IsDefault)
                                    {
                                        <button class="btn btn-outline-secondary w-100" type="button" disabled>
                                            Activates automatically
                                        </button>
                                    }
                                    else if (plan.Price == 0)
                                    {
                                        <button class="btn btn-outline-secondary w-100" type="button" disabled>
                                            Admin must set as default
                                        </button>
                                    }
                                    else if (Model.CurrentSubscription is null)
                                    {
                                        <button class="btn btn-outline-secondary w-100" type="button" disabled>
                                            Default package required
                                        </button>
                                    }
                                    else if (hasPaidPackage)
                                    {
                                        <button class="btn btn-outline-secondary w-100" type="button" disabled>
                                            Available after expiry
                                        </button>
                                    }
                                    else if (Model.PaymentConfigured)
                                    {
                                        <form method="post" asp-controller="Payment" asp-action="Checkout" class="subscription-buy-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="planId" value="@plan.Id" />
                                            <button class="btn btn-primary w-100" type="submit">Buy with VNPay</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-secondary w-100" type="button" disabled>VNPay unavailable</button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".subscription-buy-form").forEach((form) => {
            form.addEventListener("submit", (event) => {
                if (!confirm("Proceed to VNPay to pay for this package?")) {
                    event.preventDefault();
                    return;
                }

                form.querySelector("button[type='submit']").disabled = true;
            });
        });
    </script>
}
