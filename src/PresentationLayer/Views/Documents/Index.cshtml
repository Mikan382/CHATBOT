@model DocumentIndexViewModel
@{
    ViewData["Title"] = "Documents";
}

<div class="documents-page documents-layout">
    <div class="documents-upload-panel">
        <div class="card app-card">
            <div class="card-body">
                <h5 class="card-title">Upload Documents</h5>
                <p class="text-muted small">Supports PDF, DOCX, PPTX, TXT, and MD. Limit: 20MB per file.</p>
                @if (Model.CanManageDocuments)
                {
                    <form id="uploadForm" method="post" asp-controller="Documents" asp-action="Upload" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Course</label>
                            <select id="uploadCourseId" class="form-select" required>
                                @foreach (var course in Model.Courses)
                                {
                                    <option value="@course.Id">@course.Code - @course.Name</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Chapter</label>
                            <select id="uploadChapterId" class="form-select" name="chapterId" required>
                                <option value="" disabled hidden>Select a chapter</option>
                                @foreach (var chapter in Model.Chapters)
                                {
                                    <option value="@chapter.Id" data-course-id="@chapter.CourseId">@chapter.Order. @chapter.Title</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">File</label>
                            <input id="uploadFileInput" class="form-control" type="file" name="file" accept=".pdf,.docx,.pptx,.txt,.md" required />
                            <div id="uploadFileError" class="text-danger small d-none" aria-live="polite"></div>
                        </div>
                        <button id="uploadButton" class="btn btn-primary w-100" type="submit">
                            <span class="upload-button-text">Upload Document</span>
                            <span class="spinner-border spinner-border-sm d-none" aria-hidden="true"></span>
                        </button>
                    </form>
                }
                else
                {
                    <div class="alert alert-info small mb-0">Students can view indexed documents but cannot upload or delete files.</div>
                }
            </div>
        </div>
    </div>
    <div class="documents-list-panel">
        <div class="card app-card">
            <div class="card-body">
                <h5 class="card-title">Indexed Documents</h5>
                <form method="get" asp-controller="Documents" asp-action="Index" class="documents-filter-form">
                    <div>
                        <label class="form-label small text-muted" for="searchTerm">File name</label>
                        <input id="searchTerm" class="form-control form-control-sm" type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Search file name..." />
                    </div>
                    <div>
                        <label class="form-label small text-muted" for="courseId">Course</label>
                        <select id="courseId" class="form-select form-select-sm" name="courseId">
                            <option value="">All courses</option>
                            @foreach (var course in Model.Courses)
                            {
                                <option value="@course.Id" selected="@(Model.SelectedCourseId == course.Id)">@course.Code</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label small text-muted" for="chapterId">Chapter</label>
                        <select id="chapterId" class="form-select form-select-sm" name="chapterId">
                            <option value="">All chapters</option>
                            @foreach (var chapter in Model.Chapters)
                            {
                                <option value="@chapter.Id"
                                        data-course-id="@chapter.CourseId"
                                        selected="@(Model.SelectedChapterId == chapter.Id)">
                                    @chapter.Order. @chapter.Title
                                </option>
                            }
                        </select>
                    </div>
                    <div class="documents-filter-actions">
                        <button class="btn btn-sm btn-primary" type="submit">Search</button>
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="Documents" asp-action="Index">Clear</a>
                    </div>
                </form>
                <div class="table-responsive">
                    <table class="table table-sm align-middle documents-table">
                        <thead>
                        <tr>
                            <th>File</th>
                            <th>Course</th>
                            <th>Chapter</th>
                            <th>Indexing</th>
                            <th>Uploaded</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        @if (Model.Documents.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-muted small">No documents match the current filters.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var doc in Model.Documents)
                            {
                                <tr>
                                    <td><a asp-controller="Documents" asp-action="Details" asp-route-id="@doc.Id">@doc.OriginalFileName</a><br><span class="text-muted small">@doc.FileType / @(doc.FileSizeBytes / 1024) KB</span></td>
                                    <td>@doc.CourseCode</td>
                                    <td class="chapter-cell">@doc.ChapterTitle</td>
                                    <td>
                                        <div>@doc.ChunksCount sections</div>
                                        <span class="badge text-bg-light">@doc.ChunkingStrategy</span>
                                    </td>
                                    <td class="small">@doc.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                    <td class="documents-actions-cell">
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                                    type="button"
                                                    data-bs-toggle="dropdown"
                                                    aria-expanded="false">
                                                Actions
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-end">
                                                <a class="dropdown-item" asp-controller="Documents" asp-action="Details" asp-route-id="@doc.Id">View details</a>
                                                @if (Model.CanManageDocuments)
                                                {
                                                    <div class="dropdown-divider"></div>
                                                    <form method="post" asp-controller="Documents" asp-action="Delete" asp-route-id="@doc.Id" class="document-delete-form">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                                        @if (Model.SelectedCourseId.HasValue)
                                                        {
                                                            <input type="hidden" name="courseId" value="@Model.SelectedCourseId.Value" />
                                                        }
                                                        @if (Model.SelectedChapterId.HasValue)
                                                        {
                                                            <input type="hidden" name="chapterId" value="@Model.SelectedChapterId.Value" />
                                                        }
                                                        <button class="dropdown-item text-danger" type="submit">Delete document</button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="uploadProgressModal" class="modal fade upload-progress-modal" tabindex="-1" aria-labelledby="uploadProgressTitle" aria-describedby="uploadProgressDescription" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body upload-progress-body">
                <div class="spinner-border text-primary upload-progress-spinner" role="status">
                    <span class="visually-hidden">Processing document</span>
                </div>
                <h4 id="uploadProgressTitle">Indexing document</h4>
                <p id="uploadProgressDescription" class="text-muted mb-0">Extracting text, creating chunks, and generating embeddings. Keep this page open until processing finishes.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const filterCourse = document.getElementById("courseId");
        const filterChapter = document.getElementById("chapterId");
        const syncFilterChapters = () => {
            const selectedCourseId = filterCourse.value;
            let selectedChapterVisible = filterChapter.value === "";

            filterChapter.querySelectorAll("option[data-course-id]").forEach((option) => {
                const visible = !selectedCourseId || option.dataset.courseId === selectedCourseId;
                option.hidden = !visible;
                if (visible && option.value === filterChapter.value) {
                    selectedChapterVisible = true;
                }
            });

            if (!selectedChapterVisible) {
                filterChapter.value = "";
            }
        };
        filterCourse.addEventListener("change", syncFilterChapters);
        syncFilterChapters();

        document.querySelectorAll(".document-delete-form").forEach((form) => {
            form.addEventListener("submit", (event) => {
                if (!confirm("Delete this document and all related indexed sections?")) {
                    event.preventDefault();
                }
            });
        });

        const uploadForm = document.getElementById("uploadForm");
        if (uploadForm) {
            const uploadCourse = document.getElementById("uploadCourseId");
            const uploadChapter = document.getElementById("uploadChapterId");
            const uploadFileInput = document.getElementById("uploadFileInput");
            const uploadFileError = document.getElementById("uploadFileError");
            const uploadButton = document.getElementById("uploadButton");
            const uploadModal = bootstrap.Modal.getOrCreateInstance(document.getElementById("uploadProgressModal"), {
                backdrop: "static",
                keyboard: false
            });
            const chapterPlaceholder = uploadChapter.querySelector('option[value=""]');
            const maxUploadBytes = 20 * 1024 * 1024;
            let uploadInProgress = false;
            const formatMb = (bytes) => `${Math.round(bytes / 1024 / 1024)}MB`;
            const warnBeforeLeaving = (event) => {
                if (!uploadInProgress) {
                    return;
                }

                event.preventDefault();
                event.returnValue = "";
            };
            const setUploadBusy = (busy) => {
                uploadInProgress = busy;
                uploadCourse.disabled = busy;
                uploadChapter.disabled = busy;
                uploadFileInput.disabled = busy;
                uploadButton.disabled = busy;
                uploadButton.querySelector(".upload-button-text").textContent = busy ? "Processing..." : "Upload Document";
                uploadButton.querySelector(".spinner-border").classList.toggle("d-none", !busy);

                if (busy) {
                    window.addEventListener("beforeunload", warnBeforeLeaving);
                    uploadModal.show();
                } else {
                    window.removeEventListener("beforeunload", warnBeforeLeaving);
                    uploadModal.hide();
                    syncUploadChapters();
                }
            };
            const validateUploadFile = () => {
                uploadFileError.classList.add("d-none");
                uploadFileError.textContent = "";
                const file = uploadFileInput.files && uploadFileInput.files[0];
                if (!file || file.size <= maxUploadBytes) {
                    return true;
                }

                uploadFileError.textContent = `File size must be 20MB or smaller. Selected file is ${formatMb(file.size)}.`;
                uploadFileError.classList.remove("d-none");
                return false;
            };
            const syncUploadChapters = () => {
                let firstVisible = null;
                uploadChapter.querySelectorAll("option").forEach((option) => {
                    if (!option.dataset.courseId) {
                        return;
                    }
                    const visible = option.dataset.courseId === uploadCourse.value;
                    option.hidden = !visible;
                    if (visible && !firstVisible) {
                        firstVisible = option;
                    }
                });
                if (!firstVisible) {
                    chapterPlaceholder.hidden = false;
                    chapterPlaceholder.textContent = "No chapters available";
                    uploadChapter.value = "";
                    uploadChapter.disabled = true;
                    uploadButton.disabled = true;
                    return;
                }

                chapterPlaceholder.hidden = true;
                chapterPlaceholder.textContent = "Select a chapter";
                uploadChapter.disabled = false;
                uploadButton.disabled = false;
                if (!uploadChapter.selectedOptions[0] || uploadChapter.selectedOptions[0].hidden) {
                    uploadChapter.value = firstVisible.value;
                }
            };
            uploadCourse.addEventListener("change", syncUploadChapters);
            uploadFileInput.addEventListener("change", validateUploadFile);
            syncUploadChapters();

            uploadForm.addEventListener("submit", async (event) => {
                event.preventDefault();
                if (!validateUploadFile()) {
                    return;
                }

                // Build FormData BEFORE disabling inputs: disabled controls are excluded
                // from FormData, which would drop the file and cause "Please select a file".
                const uploadData = new FormData(uploadForm);
                setUploadBusy(true);
                try {
                    const response = await fetch(uploadForm.action, {
                        method: "POST",
                        body: uploadData,
                        credentials: "same-origin",
                        headers: { "X-Requested-With": "XMLHttpRequest" }
                    });
                    const contentType = response.headers.get("content-type") || "";
                    if (!response.ok) {
                        throw new Error(`Upload failed with status ${response.status}.`);
                    }

                    if (!contentType.includes("application/json")) {
                        uploadInProgress = false;
                        window.removeEventListener("beforeunload", warnBeforeLeaving);
                        window.location.assign(response.url || uploadForm.action);
                        return;
                    }

                    const result = await response.json();
                    uploadInProgress = false;
                    window.removeEventListener("beforeunload", warnBeforeLeaving);
                    window.location.assign(result.redirectUrl || window.location.href);
                } catch (error) {
                    setUploadBusy(false);
                    uploadFileError.textContent = error instanceof Error
                        ? error.message
                        : "Document upload failed. Please try again.";
                    uploadFileError.classList.remove("d-none");
                }
            });
        }

    </script>
}
