@{
    var success = TempData["Success"] as string;
    var error = TempData["Error"] as string;
    var info = TempData["Info"] as string;
}

@if (!string.IsNullOrWhiteSpace(success) || !string.IsNullOrWhiteSpace(error) || !string.IsNullOrWhiteSpace(info))
{
    <div class="flash-stack" aria-live="polite">
        @if (!string.IsNullOrWhiteSpace(success))
        {
            <div class="alert alert-success app-alert">@success</div>
        }
        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger app-alert">@error</div>
        }
        @if (!string.IsNullOrWhiteSpace(info))
        {
            <div class="alert alert-info app-alert">@info</div>
        }
    </div>
}
