@{
    ViewData["Title"] = "Architecture";
}

<div class="architecture-page">
    <header class="architecture-header">
        <div>
            <div class="architecture-kicker">Current implementation</div>
            <h2>MVC Layered Architecture</h2>
            <p>Three projects with one-way application flow and synchronous document indexing.</p>
        </div>
        <code>PresentationLayer -> BusinessLayer -> DataAccessLayer -> SQL Server</code>
    </header>

    <section class="architecture-workflows" aria-label="Application workflows">
        <article class="architecture-workflow architecture-presentation">
            <span class="architecture-step">01</span>
            <h5>Presentation</h5>
            <p>MVC Controllers, Razor Views, the Chat API, SignalR Hub, ViewModels, and browser JavaScript handle interaction and transport.</p>
            <code>Request -> Controller / Hub</code>
        </article>
        <article class="architecture-workflow architecture-business">
            <span class="architecture-step">02</span>
            <h5>Business</h5>
            <p>Services coordinate auth, courses, subscriptions, RAG, parsing, duplicate detection, chunking, and external AI clients.</p>
            <code>Service call -> DTO</code>
        </article>
        <article class="architecture-workflow architecture-data">
            <span class="architecture-step">03</span>
            <h5>Data Access</h5>
            <p>Repositories and AppDbContext own EF Core queries, entities, migrations, and SQL Server persistence.</p>
            <code>Repository -> EF Core -> SQL Server</code>
        </article>
    </section>

    <section class="architecture-section">
        <div class="architecture-section-heading">
            <h4>Runtime Workflows</h4>
            <p>All orchestration stays in BusinessLayer.</p>
        </div>
        <div class="table-responsive">
            <table class="table align-middle architecture-table">
                <thead>
                <tr>
                    <th>Workflow</th>
                    <th>Entry point</th>
                    <th>Business orchestration</th>
                    <th>Persistence / provider</th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td>Document ingestion</td>
                    <td>DocumentsController</td>
                    <td>Validate -> extract -> hash -> chunk -> embed</td>
                    <td>DocumentRepository / SQL Server</td>
                </tr>
                <tr>
                    <td>Contextual Q&amp;A</td>
                    <td>ChatHub</td>
                    <td>ChatService -> RetrievalService -> prompt</td>
                    <td>Repositories / Gemini / Hugging Face</td>
                </tr>
                <tr>
                    <td>Administration</td>
                    <td>MVC Controllers</td>
                    <td>Users, teacher assignments, subscriptions, settings</td>
                    <td>Repositories / SQL Server</td>
                </tr>
                </tbody>
            </table>
        </div>
    </section>

    <section class="architecture-scope">
        <div>
            <h4>Scope Boundary</h4>
            <p>No Razor Pages endpoints, background worker, indexing queue/progress, fine-tuned model, benchmark module, payment gateway, or deployment infrastructure.</p>
        </div>
        <div>
            <h4>Admin Configuration</h4>
            <p>The global chunking strategy is stored in SystemSettings and applies only to future uploads. Existing documents are not re-indexed automatically.</p>
        </div>
    </section>
</div>
