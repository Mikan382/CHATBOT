@model PresentationLayer.ViewModels.UserAdminIndexViewModel
@{
    ViewData["Title"] = "Users";
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card app-card">
            <div class="card-body">
                <h5 class="card-title">Create User</h5>
                <form method="post" action="/admin/users/create">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.Email"></label>
                        <input class="form-control" asp-for="CreateUser.Email" />
                        <span class="text-danger small" asp-validation-for="CreateUser.Email"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.FullName"></label>
                        <input class="form-control" asp-for="CreateUser.FullName" />
                        <span class="text-danger small" asp-validation-for="CreateUser.FullName"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.Role"></label>
                        <select class="form-select" asp-for="CreateUser.Role">
                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                        <span class="text-danger small" asp-validation-for="CreateUser.Role"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.Password"></label>
                        <input class="form-control" asp-for="CreateUser.Password" type="password" />
                        <span class="text-danger small" asp-validation-for="CreateUser.Password"></span>
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Create</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card app-card table-card">
            <div class="card-body">
                <h5 class="card-title">Users</h5>
                <div class="table-responsive">
                    <table class="table table-sm align-middle user-table">
                        <thead>
                        <tr>
                            <th>Email</th>
                            <th>Name</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.Email</td>
                                <td>@user.FullName</td>
                                <td>
                                    <form class="role-action-form" method="post" action="/admin/users/@user.Id/role">
                                        @Html.AntiForgeryToken()
                                        <select class="form-select form-select-sm" name="role">
                                            @foreach (var role in Model.Roles)
                                            {
                                                <option value="@role" selected="@(role == user.Role)">@role</option>
                                            }
                                        </select>
                                        <button class="btn btn-sm btn-outline-primary" type="submit">Save</button>
                                    </form>
                                </td>
                                <td>
                                    <span class="badge @(user.IsLockedOut ? "bg-danger" : "bg-success")">
                                        @(user.IsLockedOut ? "Locked" : "Active")
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-1 flex-nowrap">
                                        <form method="post" action="/admin/users/@user.Id/lock">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="locked" value="@(!user.IsLockedOut)" />
                                            <button class="btn btn-sm @(user.IsLockedOut ? "btn-outline-success" : "btn-outline-secondary")" type="submit" title="@(user.IsLockedOut ? "Unlock" : "Lock") user">
                                                @(user.IsLockedOut ? "Unlock" : "Lock")
                                            </button>
                                        </form>
                                        <form method="post" action="/admin/users/@user.Id/reset-password" class="d-flex gap-1 align-items-center">
                                            @Html.AntiForgeryToken()
                                            <input type="password" name="newPassword" class="form-control form-control-sm" placeholder="New password" style="width:110px" required minlength="8" />
                                            <button class="btn btn-sm btn-outline-warning" type="submit">Reset</button>
                                        </form>
                                        <form method="post" action="/admin/users/@user.Id/delete"
                                              onsubmit="return confirm('Delete @user.Email? This cannot be undone.')">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
