@model UserAdminIndexViewModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h2 class="mb-1">User Accounts</h2>
        <div class="text-muted">Create accounts, assign roles, lock access, and reset passwords.</div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert alert-danger" role="alert">@Model.Error</div>
}
<div asp-validation-summary="All" class="text-danger small mb-3"></div>

<div class="row g-3">
    <div class="col-xl-3 col-lg-4">
        <div class="card app-card">
            <div class="card-body">
                <h5 class="card-title">Create User</h5>
                <form method="post" asp-controller="AdminUsers" asp-action="Create" autocomplete="off">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.Email"></label>
                        <input class="form-control" asp-for="CreateUser.Email" autocomplete="off" />
                        <span class="text-danger small" asp-validation-for="CreateUser.Email"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.FullName">Display name</label>
                        <input class="form-control" asp-for="CreateUser.FullName" autocomplete="off" />
                        <span class="text-danger small" asp-validation-for="CreateUser.FullName"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.Role"></label>
                        <select class="form-select" asp-for="CreateUser.Role">
                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.Password"></label>
                        <input class="form-control" type="password" name="CreateUser.Password" value="" autocomplete="new-password" />
                        <span class="text-danger small" asp-validation-for="CreateUser.Password"></span>
                        <div class="form-text">At least 8 characters with upper, lower, and a digit.</div>
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Create account</button>
                </form>
            </div>
        </div>

        <div class="card app-card mt-3">
            <div class="card-body">
                <h5 class="card-title mb-1">Batch Import CSV</h5>
                <div class="text-muted small mb-3">Bulk create Student accounts from a CSV file.</div>
                <form method="post" asp-controller="AdminUsers" asp-action="ImportCsv" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Select CSV File</label>
                        <input class="form-control form-control-sm" type="file" name="csvFile" accept=".csv" required />
                        <div class="form-text text-muted small mt-1">Format: <code>FullName, Email</code></div>
                    </div>
                    <button class="btn btn-outline-success btn-sm w-100" type="submit">
                        <i class="bi bi-file-earmark-spreadsheet me-1"></i> Import CSV
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-9 col-lg-8">
        <div class="card app-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <h5 class="card-title mb-1">Manage Users</h5>
                        <div class="text-muted small">Accounts with related application data can be locked but not deleted.</div>
                    </div>
                    <span class="badge text-bg-light">@Model.Users.Count account(s)</span>
                </div>

                <form method="get" class="user-filter-form mb-3">
                    <input class="form-control form-control-sm" type="search" name="searchTerm" value="@Model.SearchTerm" placeholder="Search name or email" />
                    <select class="form-select form-select-sm" name="role">
                        <option value="">All roles</option>
                        @foreach (var role in Model.Roles)
                        {
                            <option value="@role" selected="@(role == Model.SelectedRole)">@role</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-outline-primary" type="submit">Search</button>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Clear</a>
                </form>

                @if (Model.Users.Count == 0)
                {
                    <div class="empty-state">No users match the current filter.</div>
                }
                else
                {
                    <div class="user-editor-list">
                        <div class="user-editor-header" aria-hidden="true">
                            <span>Email</span>
                            <span>Display name</span>
                            <span>Role</span>
                            <span>Status</span>
                            <span>Actions</span>
                        </div>
                        @foreach (var user in Model.Users)
                        {
                            var formId = $"update-user-{user.Id:N}";
                            var isCurrent = user.Id == Model.CurrentUserId;
                            var failed = Model.FailedUpdate?.Id == user.Id ? Model.FailedUpdate : null;
                            var email = failed?.Email ?? user.Email;
                            var fullName = failed?.FullName ?? user.DisplayName;
                            var selectedRole = failed?.Role ?? user.Role;
                            <article class="user-editor-row">
                                <div class="user-editor-fields">
                                    <input form="@formId" class="form-control form-control-sm" name="Email" value="@email" type="email" required aria-label="Email" />
                                    <input form="@formId" class="form-control form-control-sm" name="FullName" value="@fullName" required maxlength="160" aria-label="Display name" />
                                    <select form="@formId" class="form-select form-select-sm" name="Role" aria-label="Role">
                                        @foreach (var role in Model.Roles)
                                        {
                                            <option value="@role" selected="@(role == selectedRole)">@role</option>
                                        }
                                    </select>
                                    <span class="badge @(user.IsLockedOut ? "text-bg-danger" : "text-bg-success")">
                                        @(user.IsLockedOut ? "Locked" : "Active")
                                    </span>
                                    <div class="user-editor-actions">
                                        <form id="@formId" method="post" asp-action="Update">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@user.Id" />
                                            <button class="btn btn-sm btn-outline-primary" type="submit">Save</button>
                                        </form>
                                        @if (!isCurrent)
                                        {
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                                        type="button"
                                                        data-bs-toggle="dropdown"
                                                        aria-expanded="false">
                                                    Manage
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-end">
                                                    <form method="post" asp-action="@(user.IsLockedOut ? "Unlock" : "Lock")" asp-route-userId="@user.Id"
                                                          class="user-lock-form" data-locking="@(!user.IsLockedOut ? "true" : "false")">
                                                        @Html.AntiForgeryToken()
                                                        <button class="dropdown-item" type="submit">
                                                            @(user.IsLockedOut ? "Unlock account" : "Lock account")
                                                        </button>
                                                    </form>
                                                    <button class="dropdown-item"
                                                            type="button"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#resetPasswordModal"
                                                            data-reset-user-id="@user.Id"
                                                            data-reset-user-name="@user.DisplayName">
                                                        Reset password
                                                    </button>
                                                    <div class="dropdown-divider"></div>
                                                    <form method="post" asp-action="Delete" asp-route-userId="@user.Id" class="user-delete-form">
                                                        @Html.AntiForgeryToken()
                                                        <button class="dropdown-item text-danger" type="submit">Delete account</button>
                                                    </form>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="small text-muted text-nowrap">Current account</span>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-labelledby="resetPasswordTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-action="ResetPassword" id="resetPasswordForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" id="resetPasswordUserId" />
                <div class="modal-header">
                    <h5 class="modal-title" id="resetPasswordTitle">Reset password</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small" id="resetPasswordDescription"></p>
                    <label class="form-label" for="resetPasswordValue">New password</label>
                    <input class="form-control"
                           id="resetPasswordValue"
                           type="password"
                           name="newPassword"
                           required
                           minlength="8"
                           autocomplete="new-password" />
                    <div class="form-text">At least 8 characters with upper, lower, and a digit.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Reset password</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".user-lock-form").forEach((form) => {
            form.addEventListener("submit", (event) => {
                if (form.dataset.locking === "true" && !confirm("Lock this account? Its current login will be revoked.")) {
                    event.preventDefault();
                }
            });
        });

        const resetPasswordModal = document.getElementById("resetPasswordModal");
        resetPasswordModal.addEventListener("show.bs.modal", (event) => {
            const button = event.relatedTarget;
            document.getElementById("resetPasswordUserId").value = button.dataset.resetUserId;
            document.getElementById("resetPasswordDescription").textContent =
                `Set a new password for ${button.dataset.resetUserName}. Their current login will be revoked.`;
            document.getElementById("resetPasswordValue").value = "";
        });
        resetPasswordModal.addEventListener("shown.bs.modal", () => {
            document.getElementById("resetPasswordValue").focus();
        });

        document.querySelectorAll(".user-delete-form").forEach((form) => {
            form.addEventListener("submit", (event) => {
                if (!confirm("Permanently delete this account? This cannot be undone.")) {
                    event.preventDefault();
                }
            });
        });
    </script>
}
