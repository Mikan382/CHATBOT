@model ChatIndexViewModel
@{
    ViewData["Title"] = "Chat";
    var quotaExhausted = Model.Quota is not null && Model.Quota.Exhausted;
    var canSend = Model.AssistantConfigured && !quotaExhausted;
}

<div class="chat-page row g-4">
    <div class="col-lg-3 chat-sidebar">
        <div class="card app-card chat-sessions-card">
            <div class="card-header py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Recent Sessions</span>
                    <a asp-controller="Chat" asp-action="Index" class="btn btn-sm btn-primary py-0 px-2" title="Start new session">+ New</a>
                </div>
            </div>
            <div class="session-search-wrap">
                <input id="sessionSearch" type="search" class="form-control form-control-sm" placeholder="Search sessions..." autocomplete="off" />
            </div>
            <ul id="sessionList" class="list-group list-group-flush session-list"></ul>
        </div>
    </div>

    <div class="col-lg-9 chat-main">
        <div class="card app-card chat-shell">
            <div class="card-header chat-header">
                <div class="chat-header-title">
                    <strong>Ask about your course</strong>
                    <div class="small text-muted">Messages are saved for this session.</div>
                </div>
                <span id="sessionId" class="visually-hidden">@Model.SessionId</span>
                <div class="chat-header-controls">
                    <div class="chat-course-picker">
                        <label class="form-label small text-muted" for="courseId">Course</label>
                        <select id="courseId" class="form-select form-select-sm">
                            @foreach (var course in Model.Courses)
                            {
                                <option value="@course.Id" selected="@(course.Id == Model.SelectedCourseId)">@course.Code - @course.Name</option>
                            }
                        </select>
                    </div>
                    <span class="assistant-status @(Model.AssistantConfigured ? "assistant-status-ready" : "assistant-status-warning")">
                        Assistant: @(Model.AssistantConfigured ? "ready" : "not available")
                    </span>
                    @if (Model.Quota is not null)
                    {
                        <span id="chatQuotaStatus" class="assistant-status @(quotaExhausted ? "assistant-status-warning" : "assistant-status-ready")">
                            @if (!Model.Quota.HasActiveSubscription)
                            {
                                <text>No active package</text>
                            }
                            else
                            {
                                <text>Tokens left: @Model.Quota.Remaining.ToString("N0")</text>
                            }
                        </span>
                    }
                    <button id="clearButton" class="btn btn-sm btn-outline-danger" type="button">Clear</button>
                </div>
            </div>
            <div id="messages" class="chat-log">
                <div class="chat-empty-hint" id="chatEmptyHint">Ask a question to start the conversation.</div>
            </div>
            @if (Model.Quota is not null)
            {
                <div id="chatQuotaAlert" class="chat-quota-alert @(quotaExhausted ? "" : "d-none")">
                    <span id="chatQuotaAlertText">
                        @(!Model.Quota.HasActiveSubscription
                            ? "No active subscription package."
                            : $"You have used all {Model.Quota.Quota:N0} tokens in the {Model.Quota.PlanName} package.")
                    </span>
                    <a asp-controller="Subscriptions" asp-action="Index">View packages</a>.
                </div>
            }
            <form id="chatForm" class="chat-form">
                <input id="messageInput" class="form-control" autocomplete="off" maxlength="4000"
                       placeholder="Ask a question about the selected course..."
                       @(canSend ? "" : "disabled") />
                <button class="btn btn-primary" type="submit" id="sendButton"
                        @(canSend ? "" : "disabled")>Send</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script>
        window._assistantConfigured = @(Model.AssistantConfigured ? "true" : "false");
        window._quotaExhausted = @(quotaExhausted ? "true" : "false");
    </script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
