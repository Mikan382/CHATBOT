@page "/chat"
@model PresentationLayer.Pages.Chat.IndexModel
@{
    ViewData["Title"] = "Chat";
}

<div class="chat-page row g-4">
    <div class="col-lg-3 chat-sidebar">
        <div class="card app-card">
            <div class="card-header py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Recent Sessions</span>
                    <a asp-page="/Chat/Index" class="btn btn-sm btn-primary py-0 px-2" title="Start new session">+ New</a>
                </div>
            </div>
            <div class="session-search-wrap">
                <input id="sessionSearch" type="search" class="form-control form-control-sm" placeholder="Search sessions…" autocomplete="off" />
            </div>
            <ul id="sessionList" class="list-group list-group-flush session-list"></ul>
        </div>

        <div class="card app-card">
            <div class="card-body">
                <h5 class="card-title">Chat Settings</h5>
                <span id="sessionId" class="visually-hidden">@Model.SessionId</span>
                <div class="mb-3">
                    <label class="form-label small text-muted" for="courseId">Course</label>
                    <select id="courseId" class="form-select form-select-sm">
                        @foreach (var course in Model.Courses)
                        {
                            <option value="@course.Id" selected="@(course.Id == Model.SelectedCourseId)">@course.Code - @course.Name</option>
                        }
                    </select>
                </div>

                <div class="model-option">
                    <input class="form-check-input" type="radio" name="modelType" id="rag" value="rag_standard" checked>
                    <label class="form-check-label" for="rag">Course Documents</label>
                    <p class="text-muted small mb-0">Answer using the selected course documents.</p>
                </div>

                <div class="model-option">
                    <input class="form-check-input" type="radio" name="modelType" id="hybrid" value="rag_hybrid">
                    <label class="form-check-label" for="hybrid">Document + Backup Answer</label>
                    <p class="text-muted small mb-0">Use course documents first, then the backup answer service if needed.</p>
                </div>

                <div class="model-option @(Model.FineTuneConfigured ? "" : "disabled")">
                    <input class="form-check-input" type="radio" name="modelType" id="ft" value="fine_tuned_only" @(Model.FineTuneConfigured ? "" : "disabled")>
                    <label class="form-check-label" for="ft">Backup Answer Only</label>
                    <p class="text-muted small mb-0">@(Model.FineTuneConfigured ? "Backup answer service is available." : "Backup answer service is not available.")</p>
                </div>

                <div class="alert @(Model.GeminiConfigured ? "alert-success" : "alert-warning") small mt-3 mb-0">
                    Assistant: @(Model.GeminiConfigured ? "ready" : "not available — set Gemini:ApiKey")
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-9 chat-main">
        <div class="card app-card chat-shell">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>Ask about your course</strong>
                    <div class="small text-muted">Messages are saved for this session.</div>
                </div>
                <button id="clearButton" class="btn btn-sm btn-outline-danger">Clear</button>
            </div>
            <div id="messages" class="chat-log">
                <div class="chat-empty-hint" id="chatEmptyHint">Ask a question to start the conversation.</div>
            </div>
            <form id="chatForm" class="chat-form">
                <input id="messageInput" class="form-control" autocomplete="off"
                       placeholder="Ask a question about the selected course..."
                       @(Model.GeminiConfigured ? "" : "disabled") />
                <button class="btn btn-primary" type="submit" id="sendButton"
                        @(Model.GeminiConfigured ? "" : "disabled")>Send</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script>window._geminiConfigured = @(Model.GeminiConfigured ? "true" : "false");</script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
