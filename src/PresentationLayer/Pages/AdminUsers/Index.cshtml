@page "/admin/users"
@model PresentationLayer.Pages.AdminUsers.IndexModel
@{
    ViewData["Title"] = "Users";
}

<div class="row g-4 management-page">
    <div class="col-lg-4">
        <div class="card app-card management-command-card">
            <div class="card-body">
                <div class="section-kicker">Access control</div>
                <h1 class="management-title">Create User</h1>
                <p class="documents-subtitle">Provision student, teacher, and admin accounts for the course assistant.</p>
                <form method="post" asp-page-handler="Create">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.Email"></label>
                        <input class="form-control" asp-for="CreateUser.Email" />
                        <span class="text-danger small" asp-validation-for="CreateUser.Email"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.FullName"></label>
                        <input class="form-control" asp-for="CreateUser.FullName" />
                        <span class="text-danger small" asp-validation-for="CreateUser.FullName"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.Role"></label>
                        <select class="form-select" asp-for="CreateUser.Role">
                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                        <span class="text-danger small" asp-validation-for="CreateUser.Role"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="CreateUser.Password"></label>
                        <input class="form-control" asp-for="CreateUser.Password" type="password" />
                        <span class="text-danger small" asp-validation-for="CreateUser.Password"></span>
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Create</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card app-card table-card management-table-card">
            <div class="card-body">
                <div class="management-header">
                    <div>
                        <div class="section-kicker">Directory</div>
                        <h2 class="management-title">Users</h2>
                    </div>
                    <span class="document-course-chip">@Model.Users.Count accounts</span>
                </div>
                <div class="table-responsive documents-table-wrap">
                    <table class="table table-sm align-middle user-table management-table">
                        <thead>
                        <tr>
                            <th>Email</th>
                            <th>Name</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.Email</td>
                                <td>@user.FullName</td>
                                <td>
                                    <form class="role-action-form" method="post" asp-page-handler="ChangeRole" asp-route-userId="@user.Id">
                                        @Html.AntiForgeryToken()
                                        <select class="form-select form-select-sm" name="role">
                                            @foreach (var role in Model.Roles)
                                            {
                                                <option value="@role" selected="@(role == user.Role)">@role</option>
                                            }
                                        </select>
                                        <button class="btn btn-sm btn-outline-primary" type="submit">Save</button>
                                    </form>
                                </td>
                                <td>
                                    <span class="badge @(user.IsLockedOut ? "bg-danger" : "bg-success")">
                                        @(user.IsLockedOut ? "Locked" : "Active")
                                    </span>
                                </td>
                                <td>
                                    <div class="action-cell management-actions">
                                        @if (user.IsLockedOut)
                                        {
                                            <form method="post" asp-page-handler="Unlock" asp-route-userId="@user.Id">
                                                @Html.AntiForgeryToken()
                                                <button class="btn btn-sm btn-outline-success" type="submit">Unlock</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form method="post" asp-page-handler="Lock" asp-route-userId="@user.Id">
                                                @Html.AntiForgeryToken()
                                                <button class="btn btn-sm btn-outline-secondary" type="submit">Lock</button>
                                            </form>
                                        }
                                        <form method="post" asp-page-handler="ResetPassword" asp-route-userId="@user.Id" class="reset-password-form">
                                            @Html.AntiForgeryToken()
                                            <input type="password" name="newPassword" class="form-control form-control-sm" placeholder="New password" required minlength="8" />
                                            <button class="btn btn-sm btn-outline-warning" type="submit">Reset</button>
                                        </form>
                                        <form method="post" asp-page-handler="Delete" asp-route-userId="@user.Id"
                                              class="management-confirm-form"
                                              data-confirm-title="Delete user"
                                              data-confirm-message="Delete @user.Email? This cannot be undone."
                                              data-confirm-action="Delete">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="managementConfirmModal" tabindex="-1" aria-labelledby="managementConfirmTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content chat-confirm-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="managementConfirmTitle">Confirm action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="managementConfirmMessage" class="mb-0">Continue?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="managementConfirmAction" class="btn btn-outline-danger">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/management.js" asp-append-version="true"></script>
}
