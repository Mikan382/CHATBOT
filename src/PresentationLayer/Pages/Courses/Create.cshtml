@page "/courses/create"
@model PresentationLayer.Pages.Courses.CreateModel
@{
    ViewData["Title"] = "Create Course";
}

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">
        <div class="card app-card">
            <div class="card-body">
                <h4 class="card-title">@ViewData["Title"]</h4>
                <partial name="_ValidationSummary" model="Model.Input.Error" />
                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" asp-for="Input.Code"></label>
                            <input class="form-control" asp-for="Input.Code" />
                            <span class="text-danger small" asp-validation-for="Input.Code"></span>
                    </div>
                        <div class="col-md-8">
                            <label class="form-label" asp-for="Input.Name"></label>
                            <input class="form-control" asp-for="Input.Name" />
                            <span class="text-danger small" asp-validation-for="Input.Name"></span>
                    </div>
                        <div class="col-12">
                            <label class="form-label" asp-for="Input.Description"></label>
                            <textarea class="form-control" asp-for="Input.Description" rows="3"></textarea>
                    </div>
                        <div class="col-12">
                            <label class="form-label" asp-for="Input.Tools"></label>
                            <input class="form-control" asp-for="Input.Tools" />
                            <span class="text-danger small" asp-validation-for="Input.Tools"></span>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <button class="btn btn-primary" type="submit">Save</button>
                        <a class="btn btn-outline-secondary" asp-page="/Courses/Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
