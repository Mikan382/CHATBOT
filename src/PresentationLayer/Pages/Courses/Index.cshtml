@page "/courses"
@model PresentationLayer.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "Courses";
}

<div class="card app-card table-card management-table-card">
    <div class="card-body">
        <div class="page-toolbar">
            <div>
                <div class="section-kicker">Curriculum</div>
                <h1 class="management-title">Courses</h1>
                <div class="documents-subtitle">Manage courses and chapters shown to students.</div>
            </div>
            <a class="btn btn-primary" asp-page="/Courses/Create">Create Course</a>
        </div>

        <form class="management-filter-form" method="get">
            <div>
                <input class="form-control" name="searchTerm" value="@Model.SearchTerm" placeholder="Search course code or name..." />
            </div>
            <div class="documents-filter-actions">
                <button class="btn btn-primary flex-fill" type="submit">Search</button>
                <a class="btn btn-outline-secondary" asp-page="/Courses/Index">Clear</a>
            </div>
        </form>

        <div class="table-responsive documents-table-wrap">
            <table class="table table-sm align-middle management-table">
                <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Chapters</th>
                    <th>Tools</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var course in Model.CourseList)
                {
                    <tr>
                        <td><strong>@course.Code</strong></td>
                        <td>@course.Name<br><span class="text-muted small">@course.Description</span></td>
                        <td>@course.ChaptersCount</td>
                        <td class="small">@course.Tools</td>
                        <td>
                            <div class="action-cell">
                            <a class="btn btn-sm btn-outline-primary" asp-page="/Courses/Chapters" asp-route-id="@course.Id">Chapters</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-page="/Courses/Edit" asp-route-id="@course.Id">Edit</a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@course.Id"
                                  class="management-confirm-form"
                                  data-confirm-title="Delete course"
                                  data-confirm-message="Delete this course? It must have no chapters."
                                  data-confirm-action="Delete">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="managementConfirmModal" tabindex="-1" aria-labelledby="managementConfirmTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content chat-confirm-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="managementConfirmTitle">Confirm action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="managementConfirmMessage" class="mb-0">Continue?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="managementConfirmAction" class="btn btn-outline-danger">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/management.js" asp-append-version="true"></script>
}
