@page "/documents/{id:guid}"
@model PresentationLayer.Pages.Documents.DetailsModel
@{
    ViewData["Title"] = "Document Details";
    var document = Model.DocumentEntity;
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card app-card">
            <div class="card-body">
                <h5 class="card-title">@document.OriginalFileName</h5>
                <dl class="small mb-0">
                    <dt>Course</dt>
                    <dd>@document.Chapter?.Course?.Code - @document.Chapter?.Course?.Name</dd>
                    <dt>Chapter</dt>
                    <dd>@document.Chapter?.Title</dd>
                    <dt>Status</dt>
                    <dd>
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span>@document.IndexStatus</span>
                            <span class="text-muted">@document.IndexProgressPercent%</span>
                        </div>
                        <div class="progress index-progress">
                            <div class="progress-bar" role="progressbar" style="width: @document.IndexProgressPercent%;" aria-valuenow="@document.IndexProgressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="text-muted mt-1">@document.IndexStage</div>
                    </dd>
                    <dt>File</dt>
                    <dd>@document.FileType / @(document.FileSizeBytes / 1024) KB</dd>
                    <dt>Uploaded By</dt>
                    <dd>@(document.UploadedByUser?.Email ?? "Unknown")</dd>
                    <dt>Uploaded At</dt>
                    <dd>@document.UploadedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                    <dt>Sections</dt>
                    <dd>@document.Chunks.Count</dd>
                </dl>
                @if (!string.IsNullOrWhiteSpace(document.IndexError))
                {
                    <div class="alert alert-danger small mt-3">@document.IndexError</div>
                }
                <a class="btn btn-outline-secondary mt-3" asp-page="/Documents/Index">Back</a>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card app-card mb-4">
            <div class="card-body">
                <h5 class="card-title">Document Text</h5>
                <pre class="document-text">@document.ContentText</pre>
            </div>
        </div>
        <div class="card app-card">
            <div class="card-body">
                <h5 class="card-title">Indexed Sections</h5>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Content</th>
                            <th>Search Data</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var chunk in document.Chunks.OrderBy(x => x.ChunkIndex))
                        {
                            <tr>
                                <td>@chunk.ChunkIndex</td>
                                <td class="small">@chunk.Content</td>
                                <td class="small">
                                    @if (chunk.Embeddings.Count == 0)
                                    {
                                        <span class="text-muted">Not available</span>
                                    }
                                    else
                                    {
                                        @string.Join(", ", chunk.Embeddings.Select(x => x.ModelName))
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
