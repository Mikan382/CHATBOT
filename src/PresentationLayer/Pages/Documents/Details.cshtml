@page "/documents/{id:guid}"
@model PresentationLayer.Pages.Documents.DetailsModel
@{
    ViewData["Title"] = "Document Details";
    var document = Model.DocumentEntity;
}

<div class="document-detail-page">
    <aside class="document-detail-sidebar">
        <div class="card app-card document-detail-card">
            <div class="card-body">
                <div class="section-kicker">Document profile</div>
                <h1 class="document-detail-title">@document.OriginalFileName</h1>
                <p class="documents-subtitle">@document.FileType / @(document.FileSizeBytes / 1024) KB</p>

                <dl class="document-meta-list">
                    <dt>Course</dt>
                    <dd>@document.Chapter?.Course?.Code - @document.Chapter?.Course?.Name</dd>
                    <dt>Chapter</dt>
                    <dd>@document.Chapter?.Title</dd>
                    <dt>Status</dt>
                    <dd>
                        <div class="document-status-line">
                            <span class="badge @StatusClass(document.IndexStatus)">@document.IndexStatus</span>
                            <span class="small text-muted">@document.IndexProgressPercent%</span>
                        </div>
                        <div class="progress index-progress">
                            <div class="progress-bar @ProgressClass(document.IndexStatus)" role="progressbar" style="width: @document.IndexProgressPercent%;" aria-valuenow="@document.IndexProgressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="document-stage">@document.IndexStage</div>
                    </dd>
                    <dt>Uploaded By</dt>
                    <dd>@(document.UploadedByUser?.Email ?? "Unknown")</dd>
                    <dt>Uploaded At</dt>
                    <dd>@document.UploadedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                    <dt>Sections</dt>
                    <dd>@document.Chunks.Count</dd>
                </dl>

                @if (!string.IsNullOrWhiteSpace(document.IndexError))
                {
                    <div class="document-error">@document.IndexError</div>
                }

                <a class="btn btn-outline-secondary mt-3" asp-page="/Documents/Index">Back to library</a>
            </div>
        </div>
    </aside>

    <main class="document-detail-main">
        <section class="card app-card document-content-card">
            <div class="card-body">
                <div class="document-section-header">
                    <div>
                        <div class="section-kicker">Source text</div>
                        <h2 class="documents-title">Document Text</h2>
                    </div>
                </div>
                <pre class="document-text">@document.ContentText</pre>
            </div>
        </section>

        <section class="card app-card document-content-card">
            <div class="card-body">
                <div class="document-section-header">
                    <div>
                        <div class="section-kicker">Retrieval units</div>
                        <h2 class="documents-title">Indexed Sections</h2>
                    </div>
                    <span class="document-course-chip">@document.Chunks.Count sections</span>
                </div>
                <div class="table-responsive documents-table-wrap">
                    <table class="table table-sm align-middle documents-table document-chunks-table">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Content</th>
                            <th>Search Data</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var chunk in document.Chunks.OrderBy(x => x.ChunkIndex))
                        {
                            <tr>
                                <td>@chunk.ChunkIndex</td>
                                <td class="small">@chunk.Content</td>
                                <td class="small">
                                    @if (chunk.Embeddings.Count == 0)
                                    {
                                        <span class="text-muted">Not available</span>
                                    }
                                    else
                                    {
                                        @string.Join(", ", chunk.Embeddings.Select(x => x.ModelName))
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>
</div>

@functions {
    private static string StatusClass(DocumentIndexStatus status)
    {
        return status switch
        {
            DocumentIndexStatus.Indexed => "bg-success",
            DocumentIndexStatus.Failed => "bg-danger",
            DocumentIndexStatus.Processing => "bg-info",
            DocumentIndexStatus.Pending => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }

    private static string ProgressClass(DocumentIndexStatus status)
    {
        return status switch
        {
            DocumentIndexStatus.Indexed => "bg-success",
            DocumentIndexStatus.Failed => "bg-danger",
            DocumentIndexStatus.Processing => "bg-info",
            DocumentIndexStatus.Pending => "bg-warning",
            _ => "bg-secondary"
        };
    }
}
