@page "/documents"
@model PresentationLayer.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Documents";
    var totalDocuments = Model.DocumentList.Count;
    var indexedDocuments = Model.DocumentList.Count(x => x.IndexStatus == DocumentIndexStatus.Indexed);
    var activeDocuments = Model.DocumentList.Count(x => x.IndexStatus == DocumentIndexStatus.Pending || x.IndexStatus == DocumentIndexStatus.Processing);
}

<div class="documents-page documents-layout">
    <section class="documents-upload-panel">
        <div class="card app-card documents-command-card">
            <div class="card-body">
                <div class="section-kicker">Library intake</div>
                <h1 class="documents-title">Upload Documents</h1>
                <p class="documents-subtitle">Add course material for retrieval. PDF, DOCX, PPTX, TXT, and MD are supported up to 20 MB per file.</p>

                @if (Model.CanManageDocuments)
                {
                    <form id="uploadForm" method="post" asp-page-handler="Upload" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label" for="uploadCourseId">Course</label>
                            <select id="uploadCourseId" class="form-select" required>
                                @foreach (var course in Model.Courses)
                                {
                                    <option value="@course.Id">@course.Code - @course.Name</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="uploadChapterId">Chapter</label>
                            <select id="uploadChapterId" class="form-select" name="Upload.ChapterId" required>
                                <option value="" disabled hidden>Select a chapter</option>
                                @foreach (var chapter in Model.ChapterList)
                                {
                                    <option value="@chapter.Id" data-course-id="@chapter.CourseId">@chapter.Order. @chapter.Title</option>
                                }
                            </select>
                            @Html.ValidationMessage("Upload.ChapterId", null, new { @class = "text-danger small" })
                        </div>
                        <div class="document-dropzone mb-3">
                            <label class="form-label" for="uploadFileInput">File</label>
                            <input id="uploadFileInput" class="form-control" type="file" name="Upload.File" accept=".pdf,.docx,.pptx,.txt,.md" required />
                            @Html.ValidationMessage("Upload.File", null, new { @class = "text-danger small" })
                            <div id="uploadFileError" class="text-danger small d-none" aria-live="polite"></div>
                        </div>
                        <button id="uploadButton" class="btn btn-primary w-100" type="submit">
                            <span class="upload-button-text">Upload document</span>
                            <span class="spinner-border spinner-border-sm d-none" aria-hidden="true"></span>
                        </button>
                        <div id="uploadStatus" class="small text-muted mt-2 d-none" aria-live="polite">Uploading and preparing the document...</div>
                    </form>
                }
                else
                {
                    <div class="assistant-state">
                        <span class="assistant-state-dot" aria-hidden="true"></span>
                        <span>View-only access</span>
                        <small>Students can inspect indexed documents but cannot upload or delete files.</small>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="documents-list-panel">
        <div class="card app-card documents-library-card">
            <div class="card-body">
                <div class="documents-header">
                    <div>
                        <div class="section-kicker">Knowledge library</div>
                        <h2 class="documents-title">Indexed Documents</h2>
                        <p class="documents-subtitle">Filter, inspect, and monitor the material currently available to the assistant.</p>
                    </div>
                    <div class="documents-stats" aria-label="Document status summary">
                        <div>
                            <span>Total</span>
                            <strong>@totalDocuments</strong>
                        </div>
                        <div>
                            <span>Indexed</span>
                            <strong>@indexedDocuments</strong>
                        </div>
                        <div>
                            <span>Active</span>
                            <strong>@activeDocuments</strong>
                        </div>
                    </div>
                </div>

                <form method="get" class="documents-filter-form">
                    <div>
                        <label class="form-label small text-muted" for="searchTerm">File name</label>
                        <input id="searchTerm" class="form-control form-control-sm" type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Search file name..." />
                    </div>
                    <div>
                        <label class="form-label small text-muted" for="courseId">Course</label>
                        <select id="courseId" class="form-select form-select-sm" name="courseId">
                            <option value="">All courses</option>
                            @foreach (var course in Model.Courses)
                            {
                                <option value="@course.Id" selected="@(Model.SelectedCourseId == course.Id)">@course.Code</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label small text-muted" for="chapterId">Chapter</label>
                        <select id="chapterId" class="form-select form-select-sm" name="chapterId">
                            <option value="">All chapters</option>
                            @foreach (var chapter in Model.ChapterList)
                            {
                                if (Model.SelectedChapterId == chapter.Id)
                                {
                                    <option value="@chapter.Id" selected>@chapter.Order. @chapter.Title</option>
                                }
                                else
                                {
                                    <option value="@chapter.Id">@chapter.Order. @chapter.Title</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label small text-muted" for="status">Status</label>
                        <select id="status" class="form-select form-select-sm" name="status">
                            <option value="">All</option>
                            @foreach (var status in Enum.GetValues<DocumentIndexStatus>())
                            {
                                <option value="@status" selected="@(Model.SelectedStatus == status)">@status</option>
                            }
                        </select>
                    </div>
                    <div class="documents-filter-actions">
                        <button class="btn btn-sm btn-primary" type="submit">Search</button>
                        <a class="btn btn-sm btn-outline-secondary" asp-page="/Documents/Index">Clear</a>
                    </div>
                </form>

                <div class="table-responsive documents-table-wrap">
                    <table class="table table-sm align-middle documents-table">
                        <thead>
                        <tr>
                            <th>File</th>
                            <th>Course</th>
                            <th>Chapter</th>
                            <th class="status-column">Status</th>
                            <th>Sections</th>
                            <th>Uploaded</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        @if (Model.DocumentList.Count == 0)
                        {
                            <tr>
                                <td colspan="7">
                                    <div class="empty-state">No documents match the current filters.</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var doc in Model.DocumentList)
                            {
                                <tr>
                                    <td>
                                        <a class="document-file-link" asp-page="/Documents/Details" asp-route-id="@doc.Id">@doc.OriginalFileName</a>
                                        <div class="document-file-meta">@doc.FileType / @(doc.FileSizeBytes / 1024) KB</div>
                                    </td>
                                    <td><span class="document-course-chip">@doc.Chapter?.Course?.Code</span></td>
                                    <td class="chapter-cell">@doc.Chapter?.Title</td>
                                    <td>
                                        <div class="document-status-line">
                                            <span class="badge @StatusClass(doc.IndexStatus)">@doc.IndexStatus</span>
                                            <span class="small text-muted">@doc.IndexProgressPercent%</span>
                                        </div>
                                        <div class="progress index-progress" aria-label="@doc.IndexStage">
                                            <div class="progress-bar @ProgressClass(doc.IndexStatus)" role="progressbar" style="width: @doc.IndexProgressPercent%;" aria-valuenow="@doc.IndexProgressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <div class="document-stage" title="@doc.IndexStage">@doc.IndexStage</div>
                                    </td>
                                    <td>@doc.Chunks.Count</td>
                                    <td class="small">@doc.UploadedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <div class="action-cell">
                                            <a class="btn btn-sm btn-outline-primary" asp-page="/Documents/Details" asp-route-id="@doc.Id">View</a>
                                            @if (Model.CanManageDocuments)
                                            {
                                                <form method="post" asp-page-handler="Delete" asp-route-id="@doc.Id" class="document-delete-form" data-document-name="@doc.OriginalFileName">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                                    @if (Model.SelectedChapterId.HasValue)
                                                    {
                                                        <input type="hidden" name="chapterId" value="@Model.SelectedChapterId.Value" />
                                                    }
                                                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                @if (!string.IsNullOrWhiteSpace(doc.IndexError))
                                {
                                    <tr><td colspan="7"><div class="document-error">@doc.IndexError</div></td></tr>
                                }
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
</div>

<div class="modal fade" id="documentConfirmModal" tabindex="-1" aria-labelledby="documentConfirmTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content chat-confirm-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="documentConfirmTitle">Delete document</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="documentConfirmMessage" class="mb-0">Delete this document and all related indexed sections?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="documentConfirmAction" class="btn btn-outline-danger">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/documents.js" asp-append-version="true"></script>
}

@functions {
    private static string StatusClass(DocumentIndexStatus status)
    {
        return status switch
        {
            DocumentIndexStatus.Indexed => "bg-success",
            DocumentIndexStatus.Failed => "bg-danger",
            DocumentIndexStatus.Processing => "bg-info",
            DocumentIndexStatus.Pending => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }

    private static string ProgressClass(DocumentIndexStatus status)
    {
        return status switch
        {
            DocumentIndexStatus.Indexed => "bg-success",
            DocumentIndexStatus.Failed => "bg-danger",
            DocumentIndexStatus.Processing => "bg-info",
            DocumentIndexStatus.Pending => "bg-warning",
            _ => "bg-secondary"
        };
    }
}
