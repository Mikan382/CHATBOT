@page "/account/change-password"
@model PresentationLayer.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card app-card">
            <div class="card-body">
                <h4 class="card-title">Change Password</h4>

                @if (TempData["Success"] is string success)
                {
                    <div class="alert alert-success small">@success</div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Input.Error))
                {
                    <div class="alert alert-danger small">@Model.Input.Error</div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" asp-for="Input.CurrentPassword"></label>
                        <input class="form-control" asp-for="Input.CurrentPassword" autocomplete="current-password" />
                        <span class="text-danger small" asp-validation-for="Input.CurrentPassword"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Input.NewPassword"></label>
                        <input class="form-control" asp-for="Input.NewPassword" autocomplete="new-password" />
                        <span class="text-danger small" asp-validation-for="Input.NewPassword"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Input.ConfirmPassword"></label>
                        <input class="form-control" asp-for="Input.ConfirmPassword" autocomplete="new-password" />
                        <span class="text-danger small" asp-validation-for="Input.ConfirmPassword"></span>
                    </div>
                    <button class="btn btn-primary" type="submit">Save</button>
                    <a href="/" class="btn btn-outline-secondary ms-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
