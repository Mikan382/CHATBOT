@{
    ViewData["Title"] = "Component workshop";
}

<main class="workshop-page">
    <header class="workshop-heading">
        <p class="lab-eyebrow">Phase 05 · Component first</p>
        <h1>Component workshop</h1>
        <p>Every new element is rendered and reviewed here before it appears in a full reference screen.</p>
    </header>

    <div class="workshop-route-grid">
        <a asp-action="Tokens"><span>01</span><strong>Tokens</strong><small>Color, type, radius, spacing, depth</small></a>
        <a asp-action="Primitives"><span>02</span><strong>Primitives</strong><small>Buttons, inputs, badges, avatar, focus</small></a>
        <a asp-action="Composites"><span>03</span><strong>Composites</strong><small>Panels, dialogs, tabs, tables, loading</small></a>
    </div>

    <section class="workshop-rule">
        <p class="lab-eyebrow">Promotion rule</p>
        <h2>Preview. Interact. Verify. Then compose.</h2>
        <ol>
            <li>Render the component with realistic content.</li>
            <li>Show default, hover/focus, disabled, loading, empty, and error states where relevant.</li>
            <li>Check keyboard access and narrow widths.</li>
            <li>Only then reuse the exact component contract in a screen.</li>
        </ol>
    </section>
</main>
