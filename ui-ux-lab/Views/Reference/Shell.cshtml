@{
    Layout = "_ReferenceLayout";
    ViewData["Title"] = "Application shell";
}

<section class="shell-preview-content">
    <p class="lab-eyebrow">Phase 08 · Responsive shell</p>
    <h1>A quiet frame for focused study.</h1>
    <p>The rail owns global navigation. Product work lives in this fluid region without changing the shell contract.</p>
    <div class="shell-preview-grid">
        <article><span>Desktop</span><strong>72px rail</strong><p>Persistent icons with labels on hover and focus.</p></article>
        <article><span>Tablet</span><strong>Compact rail</strong><p>Content stays primary while navigation remains reachable.</p></article>
        <article><span>Mobile</span><strong>Top bar + drawer</strong><p>No permanent rail competes with the current task.</p></article>
    </div>
</section>
