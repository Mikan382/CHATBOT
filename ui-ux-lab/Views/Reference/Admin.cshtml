@{
    Layout = "_ReferenceLayout";
    ViewData["Title"] = "Admin user management reference";
    var state = ViewData["State"]?.ToString() ?? "ready";
}
<div class="admin-reference">
    <header class="reference-page-heading"><div><p class="lab-eyebrow">Phase 18 · Administration</p><h1>People &amp; access</h1><p>Review roles and account health with explicit safeguards around high-impact actions.</p></div><button class="ui-button ui-button-primary" data-bs-toggle="modal" data-bs-target="#inviteModal">Invite user</button></header>
    <section class="admin-summary"><article><span>Total users</span><strong>184</strong><small>+12 this semester</small></article><article><span>Teachers</span><strong>14</strong><small>Across 6 courses</small></article><article><span>Locked accounts</span><strong>3</strong><small class="metric-warning">Needs review</small></article></section>
    <section class="admin-panel"><header><div><p class="lab-eyebrow">Directory</p><h2>User accounts</h2></div><div class="admin-filters"><input type="search" aria-label="Search users" placeholder="Search name or email…" /><select aria-label="Filter by role"><option>All roles</option><option>Teacher</option><option>Student</option><option>Admin</option></select></div></header>
        @if (state == "empty") { <div class="document-empty"><span>◎</span><h3>No matching users</h3><p>Try a broader name, email, or role filter.</p></div> }
        else { <div class="ui-table-scroll"><table class="admin-table"><thead><tr><th>User</th><th>Role</th><th>Courses</th><th>Last active</th><th>Status</th><th></th></tr></thead><tbody data-live-users>
            <tr><td><span class="ui-avatar">AJ</span><div><strong>Alex Johnson</strong><small>alex.johnson@fpt.edu.vn</small></div></td><td><span class="role-pill role-admin">Admin</span></td><td>All courses</td><td>2 minutes ago</td><td><span class="ui-badge ui-badge-success"><i></i>Active</span></td><td><button class="ui-icon-button" aria-label="Actions for Alex Johnson">•••</button></td></tr>
            <tr><td><span class="ui-avatar avatar-teacher">NL</span><div><strong>Nguyen Lan</strong><small>lan.nguyen@fpt.edu.vn</small></div></td><td><span class="role-pill role-teacher">Teacher</span></td><td>PRN222, SWD392</td><td>Today, 09:18</td><td><span class="ui-badge ui-badge-success"><i></i>Active</span></td><td><button class="ui-icon-button" aria-label="Actions for Nguyen Lan">•••</button></td></tr>
            <tr class="account-locked"><td><span class="ui-avatar avatar-student">TM</span><div><strong>Tran Minh</strong><small>minh.tran@fpt.edu.vn</small></div></td><td><span class="role-pill">Student</span></td><td>PRN222</td><td>Jul 12, 16:40</td><td><span class="ui-badge ui-badge-danger"><i></i>Locked</span></td><td><button class="ui-button ui-button-secondary" data-bs-toggle="modal" data-bs-target="#unlockModal">Review</button></td></tr>
        </tbody></table></div> }
    </section>
</div>
<div class="modal fade" id="inviteModal" tabindex="-1" aria-labelledby="inviteTitle" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content ui-dialog"><div class="modal-body"><p class="lab-eyebrow">Account invitation</p><h2 id="inviteTitle">Invite someone</h2><form class="course-form"><label class="ui-field"><span>Institutional email</span><input type="email" placeholder="name@fpt.edu.vn" /></label><label class="ui-field"><span>Initial role</span><select><option>Student</option><option>Teacher</option><option>Administrator</option></select></label></form><div class="ui-dialog-actions"><button class="ui-button ui-button-quiet" data-bs-dismiss="modal">Cancel</button><button class="ui-button ui-button-primary" data-bs-dismiss="modal">Send preview</button></div></div></div></div></div>
<div class="modal fade" id="unlockModal" tabindex="-1" aria-labelledby="unlockTitle" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content ui-dialog"><div class="modal-body"><p class="lab-eyebrow">Account safeguard</p><h2 id="unlockTitle">Unlock Tran Minh?</h2><p>The account was locked after five failed sign-in attempts. Confirm the learner's identity before restoring access.</p><div class="admin-audit-note"><strong>Audit trail</strong><span>Reason and administrator identity will be recorded by the existing application.</span></div><div class="ui-dialog-actions"><button class="ui-button ui-button-quiet" data-bs-dismiss="modal">Keep locked</button><button class="ui-button ui-button-primary" data-bs-dismiss="modal">Unlock account</button></div></div></div></div></div>
