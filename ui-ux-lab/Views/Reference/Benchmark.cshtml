@{
    Layout = "_ReferenceLayout";
    ViewData["Title"] = "Benchmark dashboard reference";
    var state = ViewData["State"]?.ToString() ?? "ready";
}

<div class="benchmark-reference">
    <header class="reference-page-heading"><div><p class="lab-eyebrow">Phase 17 · Evaluation</p><h1>Answer benchmark</h1><p>Compare retrieval quality, groundedness, latency, and cost before changing the learner experience.</p></div><button class="ui-button ui-button-primary" type="button" data-busy-demo><span>Run benchmark</span></button></header>
    @if (state == "running")
    {
        <section class="benchmark-run" aria-live="polite"><div><p class="lab-eyebrow">Run B-1042 · In progress</p><h2>Evaluating 64 questions</h2><p>Retrieval and answer generation are running in the background. You may leave this page.</p></div><strong>41 / 64</strong><div class="benchmark-progress"><span style="width:64%"></span></div><small>Current case: Middleware ordering and short-circuiting</small></section>
    }
    <section class="benchmark-kpis" aria-label="Latest benchmark summary"><article><span>Groundedness</span><strong>91.4%</strong><small class="metric-up">↑ 3.2 points</small></article><article><span>Retrieval recall</span><strong>87.8%</strong><small class="metric-up">↑ 1.6 points</small></article><article><span>Median latency</span><strong>1.82s</strong><small class="metric-up">↓ 240 ms</small></article><article><span>Estimated cost</span><strong>$0.041</strong><small>per question</small></article></section>
    <div class="benchmark-grid">
        <section class="benchmark-panel benchmark-setup"><header><div><p class="lab-eyebrow">Experiment setup</p><h2>Configure a run</h2></div><span class="ui-badge ui-badge-success"><i></i>64 cases</span></header><form><label class="ui-field"><span>Dataset</span><select><option>PRN222 verified questions · v3</option></select></label><div class="field-grid"><label class="ui-field"><span>Course</span><select><option>PRN222</option></select></label><label class="ui-field"><span>Retriever</span><select><option>Hybrid · top 5</option></select></label><label class="ui-field"><span>Answer model</span><select><option>Configured application model</option></select></label></div><label class="ui-field"><span>Run note</span><input placeholder="What changed in this experiment?" /></label><div class="benchmark-form-actions"><button class="ui-button ui-button-secondary" type="button">Validate dataset</button><button class="ui-button ui-button-primary" type="button">Start background run</button></div></form></section>
        <section class="benchmark-panel benchmark-chart"><header><div><p class="lab-eyebrow">Quality comparison</p><h2>Current vs. baseline</h2></div><button class="ui-button ui-button-quiet" type="button">Export CSV</button></header><div class="metric-chart" role="img" aria-label="Current run quality across four metrics"><div><span>Groundedness</span><i><b style="width:91%"></b></i><strong>91</strong></div><div><span>Retrieval recall</span><i><b style="width:88%"></b></i><strong>88</strong></div><div><span>Citation precision</span><i><b style="width:94%"></b></i><strong>94</strong></div><div><span>Answer relevance</span><i><b style="width:86%"></b></i><strong>86</strong></div></div><div class="chart-legend"><span><i class="legend-current"></i>Current B-1041</span><span><i class="legend-baseline"></i>Baseline B-1037</span></div></section>
    </div>
    <section class="benchmark-panel benchmark-history"><header><div><p class="lab-eyebrow">Recent runs</p><h2>Experiment history</h2></div><label class="ui-field"><span class="visually-hidden">Filter runs</span><select><option>All statuses</option><option>Completed</option><option>Failed</option></select></label></header><div class="ui-table-scroll"><table class="ui-table"><thead><tr><th>Run</th><th>Change note</th><th>Score</th><th>Latency</th><th>Status</th><th></th></tr></thead><tbody><tr><td><strong>B-1041</strong><br /><small>Today, 11:24</small></td><td>Hybrid retrieval, top 5</td><td>90.1</td><td>1.82s</td><td><span class="ui-badge ui-badge-success"><i></i>Completed</span></td><td><button class="ui-button ui-button-secondary">Compare</button></td></tr><tr><td><strong>B-1040</strong><br /><small>Yesterday</small></td><td>Chunk size 700</td><td>86.9</td><td>1.64s</td><td><span class="ui-badge ui-badge-success"><i></i>Completed</span></td><td><button class="ui-button ui-button-secondary">Compare</button></td></tr><tr><td><strong>B-1039</strong><br /><small>Jul 14</small></td><td>Reranker candidate</td><td>—</td><td>—</td><td><span class="ui-badge ui-badge-danger"><i></i>Failed</span></td><td><button class="ui-button ui-button-secondary">Inspect</button></td></tr></tbody></table></div></section>
</div>
