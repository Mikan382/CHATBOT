@{
    ViewData["Title"] = "Sign in reference";
    var state = ViewData["State"]?.ToString() ?? "default";
}

<main class="auth-reference">
    <section class="auth-story">
        <a class="auth-mark" asp-controller="Home" asp-action="Index">P</a>
        <div><p class="lab-eyebrow">PRN222 Course Assistant</p><h1>Study with the material your course actually uses.</h1><p>Ask grounded questions, inspect citations, and return to the sessions that matter.</p></div>
        <blockquote>“The citation trail makes it easy to move from an answer back into the lecture material.”<cite>Student preview</cite></blockquote>
    </section>
    <section class="auth-form-panel" aria-labelledby="sign-in-title">
        <div class="auth-form-wrap">
            <p class="lab-eyebrow">Phase 09 · Authentication boundary</p>
            <h2 id="sign-in-title">Welcome back</h2>
            <p>Use the same account as the current PRN222 application.</p>
            @if (state == "error")
            {
                <div class="auth-alert" role="alert"><strong>Sign-in failed.</strong><span>Check your email and password, then try again.</span></div>
            }
            else if (state == "success")
            {
                <div class="auth-alert auth-alert-success" role="status"><strong>Credentials accepted.</strong><span>The reference preview does not create a real session.</span></div>
            }
            <form class="auth-form" data-auth-demo novalidate>
                <label class="ui-field"><span>Email</span><input name="email" type="email" autocomplete="email" value="student@prn222.local" required /><small>Use your assigned course account.</small></label>
                <label class="ui-field"><span>Password</span><input name="password" type="password" autocomplete="current-password" minlength="8" required /><small>At least 8 characters.</small></label>
                <div class="auth-meta"><label><input type="checkbox" /> Keep me signed in on this device</label><a href="#">Need help?</a></div>
                <button class="ui-button ui-button-primary" type="submit" @(state == "loading" ? "disabled aria-busy=true" : "")><span>@(state == "loading" ? "Signing in…" : "Sign in")</span></button>
            </form>
            <p class="auth-footnote">Reference only. No credential is submitted or stored by the lab.</p>
        </div>
    </section>
</main>
