@{
    Layout = "_ReferenceLayout";
    ViewData["Title"] = "Chat workspace reference";
}

<div class="chat-workspace" data-chat-workspace>
    <aside class="session-rail" id="sessionRail" aria-label="Saved chat sessions">
        <div class="session-rail-header"><div><p class="lab-eyebrow">Phase 10 · Chat</p><h1>Sessions</h1></div><button class="ui-button ui-button-primary" type="button">+ New</button></div>
        <label class="session-search"><span class="visually-hidden">Search sessions</span><input type="search" placeholder="Search sessions…" /></label>
        <div class="session-list-placeholder"><p>Session management arrives in Phase 11.</p></div>
    </aside>

    <section class="conversation" aria-labelledby="conversation-title">
        <header class="conversation-header">
            <button class="ui-icon-button session-mobile-toggle" type="button" data-session-toggle aria-controls="sessionRail" aria-expanded="false" aria-label="Open sessions">☷</button>
            <div class="conversation-course"><span>Current course</span><button type="button">PRN222 · .NET Development⌄</button></div>
            <div class="conversation-heading"><h2 id="conversation-title">Advanced MVC patterns</h2><p>Messages are grounded in the selected course.</p></div>
            <div class="conversation-actions"><span class="ui-badge ui-badge-success"><i></i>Connected</span><button class="ui-button ui-button-quiet" type="button">Clear</button></div>
        </header>
        <div class="message-scroll" aria-live="polite">
            <div class="chat-stage-note"><span>Conversation surface</span><h3>Long-form answers stay readable and sourced.</h3><p>Phase 12 will add the complete message, citation, generating, and failure contracts.</p></div>
        </div>
        <footer class="composer-frame"><textarea rows="2" placeholder="Ask about PRN222…" aria-label="Message"></textarea><button class="ui-button ui-button-primary" type="button">Send</button></footer>
    </section>
</div>
