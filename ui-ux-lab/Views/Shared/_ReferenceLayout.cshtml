<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - PRN222 UI Lab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=JetBrains+Mono:wght@500&amp;family=Source+Serif+4:opsz,wght@@8..60,600;8..60,700&amp;display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="reference-body">
    @{ var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty; }
    <a class="skip-link" href="#reference-main">Skip to content</a>
    <div class="reference-shell" data-reference-shell>
        <aside class="global-rail" id="globalRail" aria-label="Primary navigation">
            <a class="rail-logo" asp-controller="Reference" asp-action="Shell" aria-label="PRN222 home">P</a>
            <nav>
                <a class="@(currentAction == "Chat" ? "active" : null)" asp-controller="Reference" asp-action="Chat" aria-current="@(currentAction == "Chat" ? "page" : null)"><span aria-hidden="true">✦</span><b>Chat</b></a>
                <a class="@(currentAction is "Documents" or "DocumentDetails" ? "active" : null)" asp-controller="Reference" asp-action="Documents" aria-current="@(currentAction is "Documents" or "DocumentDetails" ? "page" : null)"><span aria-hidden="true">▤</span><b>Documents</b></a>
                <a class="@(currentAction == "Courses" ? "active" : null)" asp-controller="Reference" asp-action="Courses" aria-current="@(currentAction == "Courses" ? "page" : null)"><span aria-hidden="true">◇</span><b>Courses</b></a>
                <a class="@(currentAction == "Benchmark" ? "active" : null)" asp-controller="Reference" asp-action="Benchmark" aria-current="@(currentAction == "Benchmark" ? "page" : null)"><span aria-hidden="true">⌁</span><b>Benchmark</b></a>
                <a href="#"><span aria-hidden="true">◎</span><b>Users</b></a>
                <a href="#"><span aria-hidden="true">⚙</span><b>Settings</b></a>
            </nav>
            <div class="rail-account">
                <button class="ui-icon-button rail-theme" type="button" data-theme-toggle aria-label="Toggle contrast theme">◐</button>
                <span class="ui-avatar" role="img" aria-label="Alex Johnson">AJ</span>
            </div>
        </aside>
        <header class="reference-topbar">
            <button class="ui-icon-button mobile-menu" type="button" data-rail-toggle aria-controls="globalRail" aria-expanded="false" aria-label="Open navigation">☰</button>
            <div><strong>PRN222 Assistant</strong><small>Academic workspace</small></div>
            <span class="ui-badge ui-badge-success"><i></i>Connected</span>
        </header>
        <main class="reference-main" id="reference-main" tabindex="-1">
            @RenderBody()
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
